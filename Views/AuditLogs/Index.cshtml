@model List<PmesCSharp.Models.AuditLog>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Audit Logs";

    var currentPage = (int)(ViewBag.Page ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<div class="bg-gray-900/40 border border-gray-800/50 rounded-2xl p-8">
    <div class="flex items-center justify-between gap-4 mb-6">
        <div>
            <div class="text-xs font-bold text-gray-500 uppercase tracking-[0.2em]">System</div>
            <h2 class="text-xl font-extrabold text-white tracking-tight mt-1">Audit Logs</h2>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-[11px] font-bold text-gray-600 uppercase tracking-wider border-b border-gray-800/60">
                    <th class="py-3 pr-4">Time (UTC)</th>
                    <th class="py-3 pr-4">Action</th>
                    <th class="py-3 pr-4">Entity</th>
                    <th class="py-3 pr-4">Actor</th>
                    <th class="py-3 pr-4">IP</th>
                    <th class="py-3 pr-4">Details</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800/40">
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="py-6 text-gray-500">No audit logs yet.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="text-gray-300">
                            <td class="py-3 pr-4 whitespace-nowrap">@item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td class="py-3 pr-4 font-semibold text-white">@item.Action</td>
                            <td class="py-3 pr-4">
                                <div class="text-white">@item.EntityType</div>
                                <div class="text-xs text-gray-500">@item.EntityId</div>
                            </td>
                            <td class="py-3 pr-4">@item.ActorUserId</td>
                            <td class="py-3 pr-4">@item.IpAddress</td>
                            <td class="py-3 pr-4 max-w-[520px]">
                                <div class="text-gray-400 truncate" title="@item.Details">@item.Details</div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="flex items-center justify-between mt-6">
        <div class="text-xs text-gray-500">Page @currentPage of @totalPages</div>
        <div class="flex gap-2">
            @if (currentPage > 1)
            {
                <a class="px-4 py-2 rounded-xl bg-white/[0.03] border border-white/[0.06] text-sm font-semibold text-gray-300 hover:text-white" href="/admin/audit-logs?page=@(currentPage-1)">Prev</a>
            }
            @if (currentPage < totalPages)
            {
                <a class="px-4 py-2 rounded-xl bg-white/[0.03] border border-white/[0.06] text-sm font-semibold text-gray-300 hover:text-white" href="/admin/audit-logs?page=@(currentPage+1)">Next</a>
            }
        </div>
    </div>
</div>
