@model List<PmesCSharp.Models.AuditLog>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Audit Logs";
    var currentPage = (int)(ViewBag.Page ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h2 class="text-2xl font-bold text-white tracking-tight">Audit Logs</h2>
            <p class="text-sm text-gray-500 mt-1">Track all system actions and changes.</p>
        </div>
        <div class="text-xs text-gray-600 bg-gray-900 px-3 py-1.5 rounded-full border border-gray-800">
            Page @currentPage of @totalPages
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-separate border-spacing-y-2">
            <thead>
                <tr class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">
                    <th class="px-4 py-3">Time (UTC)</th>
                    <th class="px-4 py-3">Action</th>
                    <th class="px-4 py-3">Entity</th>
                    <th class="px-4 py-3">Actor</th>
                    <th class="px-4 py-3">IP</th>
                    <th class="px-4 py-3">Details</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="px-4 py-10 text-sm text-gray-500">No audit logs yet.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    var normalizedAction = (item.Action ?? string.Empty).ToLowerInvariant();
                    var isProductAction = item.EntityType == "Product" || normalizedAction.Contains("product");
                    var isProductionAction = item.EntityType == "ProductionSchedule" || item.EntityType == "WorkOrder" || normalizedAction.Contains("production") || normalizedAction.Contains("schedule") || normalizedAction.Contains("workorder") || normalizedAction.Contains("work_order") || normalizedAction.Contains("work-orders");
                    var actionColor = normalizedAction.Contains("delete") || normalizedAction.Contains("cancel") || normalizedAction.Contains("revoke")
                        ? "text-red-400 bg-red-500/10 border-red-500/20"
                        : isProductAction && (normalizedAction.Contains("create") || normalizedAction.Contains("update") || normalizedAction.Contains("archive") || normalizedAction.Contains("unarchive"))
                            ? "text-fuchsia-300 bg-fuchsia-500/10 border-fuchsia-500/20"
                            : isProductionAction
                                ? "text-orange-300 bg-orange-500/10 border-orange-500/20"
                                : normalizedAction.Contains("create") || normalizedAction.Contains("setup") || normalizedAction.Contains("activated")
                                    ? "text-emerald-400 bg-emerald-500/10 border-emerald-500/20"
                                    : normalizedAction.Contains("update") || normalizedAction.Contains("set")
                                        ? "text-blue-400 bg-blue-500/10 border-blue-500/20"
                                        : "text-gray-400 bg-white/5 border-white/10";

                    <tr class="bg-white/[0.02] hover:bg-white/[0.04] transition-colors">
                        <td class="px-4 py-3 rounded-l-xl border-y border-l border-white/[0.04]">
                            <div class="text-xs text-gray-400 whitespace-nowrap">@item.CreatedAt.ToString("MMM dd, yyyy")</div>
                            <div class="text-[11px] text-gray-600">@item.CreatedAt.ToString("HH:mm:ss")</div>
                        </td>
                        <td class="px-4 py-3 border-y border-white/[0.04]">
                            <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-1 rounded-lg border @actionColor">
                                @item.Action
                            </span>
                        </td>
                        <td class="px-4 py-3 border-y border-white/[0.04]">
                            <div class="text-sm font-semibold text-gray-200">@(item.EntityType ?? "—")</div>
                            <div class="text-xs text-gray-600">@(item.EntityId ?? "")</div>
                        </td>
                        <td class="px-4 py-3 border-y border-white/[0.04]">
                            <div class="text-xs text-gray-400">@(item.ActorUser?.FullName ?? item.ActorUser?.Email ?? item.ActorUserId ?? "—")</div>
                        </td>
                        <td class="px-4 py-3 border-y border-white/[0.04]">
                            <div class="text-xs text-gray-500 font-mono">@(item.IpAddress ?? "—")</div>
                        </td>
                        <td class="px-4 py-3 rounded-r-xl border-y border-r border-white/[0.04] max-w-xs">
                            <div class="text-xs text-gray-400 truncate" title="@item.Details">@(item.Details ?? "—")</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="mt-6 flex items-center justify-between">
            <div class="text-xs text-gray-600">Page @currentPage of @totalPages</div>
            <div class="flex items-center gap-2">
                @if (currentPage > 1)
                {
                    <a href="/admin/audit-logs?page=@(currentPage-1)" class="px-4 py-2 text-xs font-bold rounded-xl bg-white/[0.03] hover:bg-white/[0.08] border border-white/[0.05] text-gray-300 transition-all">← Prev</a>
                }
                @if (currentPage < totalPages)
                {
                    <a href="/admin/audit-logs?page=@(currentPage+1)" class="px-4 py-2 text-xs font-bold rounded-xl bg-white/[0.03] hover:bg-white/[0.08] border border-white/[0.05] text-gray-300 transition-all">Next →</a>
                }
            </div>
        </div>
    }
</div>
