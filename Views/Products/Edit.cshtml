@model PmesCSharp.ViewModels.Products.ProductFormViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Product";
    var productId = ViewBag.ProductId;
}

<div class="max-w-3xl">
    <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
        <div class="mb-8">
            <h2 class="text-2xl font-bold text-white tracking-tight">Edit Product</h2>
            <p class="text-sm text-gray-500 mt-1">Update SKU details.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            var errors = ViewData.ModelState.Values.SelectMany(v => v.Errors).ToList();
            if (errors.Count > 0)
            {
                <div class="mb-6 p-4 rounded-2xl bg-red-500/10 border border-red-500/20 text-sm text-red-300">
                    @errors[0].ErrorMessage
                </div>
            }
        }

        <form method="post" action="/admin/products/@productId/edit" class="space-y-6">
            @Html.AntiForgeryToken()

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Product Code</label>
                    <input type="text" name="ProductCode" value="@Model.ProductCode"
                        class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Status</label>
                    <select name="Status" class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500">
                        @if (Model.Status == "active") { <option value="active" selected>Active</option> } else { <option value="active">Active</option> }
                        @if (Model.Status == "inactive") { <option value="inactive" selected>Inactive</option> } else { <option value="inactive">Inactive</option> }
                    </select>
                </div>
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Product Name</label>
                <input type="text" name="ProductName" value="@Model.ProductName"
                    class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500">
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Description (optional)</label>
                <textarea name="Description" rows="3"
                    class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500">@Model.Description</textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Unit Price</label>
                    <input type="number" step="0.01" min="0" name="UnitPrice" value="@Model.UnitPrice"
                        class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500"
                        placeholder="Optional (defaults to 0)">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Unit</label>
                    <input type="text" name="Unit" value="@Model.Unit"
                        class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500"
                        placeholder="pcs">
                    <div class="mt-2 text-xs text-gray-600">Quantity is set when creating a schedule.</div>
                </div>
            </div>

            <div class="flex items-center justify-end gap-3 pt-4 border-t border-white/[0.05]">
                <a href="/admin/products" class="px-6 py-3 bg-white/[0.03] hover:bg-white/[0.08] text-white text-sm font-bold rounded-xl border border-white/[0.05] transition-all">Back</a>
                <button type="submit" class="px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-orange-900/20">Save Changes</button>
            </div>
        </form>
    </div>
</div>
