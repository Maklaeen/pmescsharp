@model List<PmesCSharp.Models.Product>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Products Management";
    int page = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
}

@if (TempData["Success"] is string success)
{
    <div class="mb-6 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm px-4 py-3 rounded-xl">
        @success
    </div>
}

@if (TempData["Error"] is string error)
{
    <div class="mb-6 bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-4 py-3 rounded-xl">
        @error
    </div>
}

<div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
    <div class="flex items-center justify-between mb-10">
        <div>
            <h2 class="text-2xl font-bold text-white tracking-tight">Product Catalog</h2>
            <p class="text-sm text-gray-500 mt-1">Manage finished goods and SKU details.</p>
        </div>
        <div class="flex items-center gap-3">
            @if (!(ViewBag.ShowArchived == true))
            {
                <a href="/admin/products?archived=true" class="px-4 py-2 bg-white/[0.03] hover:bg-white/[0.06] text-sm font-semibold rounded-xl border border-white/[0.05] text-gray-300">Archived (@(ViewBag.ArchivedCount ?? 0))</a>
            }
            else
            {
                <a href="/admin/products" class="px-4 py-2 bg-white/[0.03] hover:bg-white/[0.06] text-sm font-semibold rounded-xl border border-white/[0.05] text-gray-300">Back to active</a>
            }
            <a href="/admin/products/create" class="px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-orange-900/20">Create Product</a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="py-20 flex flex-col items-center justify-center text-center">
            <div class="w-20 h-20 bg-gray-900 rounded-3xl flex items-center justify-center text-gray-700 mb-6">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">No Products Found</h3>
            <p class="text-gray-500 max-w-sm">You haven't added any products yet. Start by creating your first SKU.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var product in Model)
            {
                <div class="bg-white/[0.02] border border-white/[0.05] rounded-3xl p-6 hover:bg-white/[0.04] transition-all group">
                    <div class="flex items-start justify-between mb-6">
                        <div class="w-14 h-14 bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-500 border border-emerald-500/10">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        </div>
                        <div class="px-3 py-1 @(product.Status == "active" ? "bg-emerald-500/5 border-emerald-500/10" : "bg-gray-500/5 border-gray-500/10") border rounded-full">
                            <span class="text-[10px] font-bold @(product.Status == "active" ? "text-emerald-500" : "text-gray-500") uppercase tracking-widest">@product.Status</span>
                        </div>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-1 group-hover:text-orange-500 transition-colors">@product.ProductName</h3>
                    <p class="text-sm text-gray-500 mb-6 line-clamp-2">@product.Description</p>
                    <div class="flex items-center justify-between pt-6 border-t border-white/[0.05]">
                        <div class="text-xs font-bold text-gray-400 uppercase tracking-widest">Code: @product.ProductCode</div>
                        <div class="inline-flex items-center gap-2">
                            <a href="/admin/products/@product.Id/edit" class="px-3 py-1 bg-white/[0.03] hover:bg-white/[0.06] border border-white/[0.05] rounded-lg text-sm font-semibold text-orange-500 transition">Edit</a>
                            @if (ViewBag.ShowArchived == true)
                            {
                                <form method="post" action="/admin/products/@product.Id/status-unarchive" onsubmit="return confirm('Unarchive this product?');" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="px-4 py-2 text-xs font-bold rounded-xl bg-emerald-600/20 hover:bg-emerald-600/30 border border-emerald-500/30 text-emerald-300 transition-all">Unarchive</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" action="/admin/products/@product.Id/status-archive" onsubmit="return confirm('Archive this product?');" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="px-4 py-2 text-xs font-bold rounded-xl bg-red-600/20 hover:bg-red-600/30 border border-red-500/30 text-red-300 transition-all">Archive</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (totalPages > 1)
        {
            <div class="mt-8 flex items-center gap-2">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <a href="/admin/products?page=@i" class="px-4 py-2 text-xs font-bold rounded-xl @(i == page ? "bg-orange-600 text-white" : "bg-white/[0.03] text-gray-400 hover:bg-white/[0.08]") border border-white/[0.05] transition-all">@i</a>
                }
            </div>
        }
    }
</div>
