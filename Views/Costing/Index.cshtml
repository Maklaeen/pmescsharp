@model List<PmesCSharp.Models.ProductionSchedule>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Production Costing";
    int page = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
}

@if (TempData["Success"] is string success)
{
    <div class="mb-6 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm px-4 py-3 rounded-xl">@success</div>
}

<div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h2 class="text-2xl font-bold text-white tracking-tight">Production Costing</h2>
            <p class="text-sm text-gray-500 mt-1">In-progress schedules and latest computed cost.</p>
        </div>
        <a href="/production/schedules" class="px-6 py-3 bg-white/[0.03] hover:bg-white/[0.08] text-white text-sm font-bold rounded-xl border border-white/[0.05] transition-all">View Schedules</a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-separate border-spacing-y-3">
            <thead>
                <tr class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">
                    <th class="px-6 py-4">Schedule</th>
                    <th class="px-6 py-4">Product</th>
                    <th class="px-6 py-4">Started</th>
                    <th class="px-6 py-4">Cost / Unit</th>
                    <th class="px-6 py-4">Computed At</th>
                    <th class="px-6 py-4 text-right">Open</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="6" class="px-6 py-10 text-sm text-gray-500">No schedules found.</td></tr>
                }
                @foreach (var s in Model)
                {
                    var cost = s.ProductionCost;
                    <tr class="bg-white/[0.02] hover:bg-white/[0.05] transition-colors">
                        <td class="px-6 py-5 rounded-l-2xl border-y border-l border-white/[0.05]">
                            <div class="text-sm font-bold text-white">#@s.Id</div>
                            <div class="text-xs text-gray-500">@s.ScheduleDate.ToString("MMM dd, yyyy")</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-sm font-semibold text-gray-200">@(s.Product?.ProductName ?? "—")</div>
                            <div class="text-xs text-gray-600">@(s.Product?.ProductCode ?? "")</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-xs text-gray-300 font-semibold">@(s.StartedAt?.ToString("MMM dd, yyyy HH:mm") ?? "—")</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-sm font-extrabold @(cost is not null ? "text-orange-400" : "text-gray-500")">
                                @(cost is not null ? cost.CostPerUnit.ToString("N4") : "—")
                            </div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-xs text-gray-500">@(cost?.ComputedAt?.ToString("MMM dd, yyyy HH:mm") ?? "—")</div>
                        </td>
                        <td class="px-6 py-5 rounded-r-2xl border-y border-r border-white/[0.05] text-right">
                            <a href="/production/schedules/@s.Id" class="px-4 py-2 text-xs font-bold rounded-xl bg-white/[0.03] hover:bg-white/[0.08] border border-white/[0.05] text-white transition-all">Open</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="mt-6 flex items-center gap-2">
            @for (int i = 1; i <= totalPages; i++)
            {
                <a href="/costing?page=@i" class="px-4 py-2 text-xs font-bold rounded-xl @(i == page ? "bg-orange-600 text-white" : "bg-white/[0.03] text-gray-400 hover:bg-white/[0.08]") border border-white/[0.05] transition-all">@i</a>
            }
        </div>
    }
</div>
