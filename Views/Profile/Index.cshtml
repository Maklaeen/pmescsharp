@model PmesCSharp.Models.ApplicationUser
@using Microsoft.AspNetCore.Identity
@inject UserManager<PmesCSharp.Models.ApplicationUser> UserManager
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "My Profile";
    var roles = await UserManager.GetRolesAsync(Model);
    var roleName = roles.FirstOrDefault() ?? "N/A";
    var initials = new string((Model.FullName ?? Model.Email ?? "?").Take(2).ToArray()).ToUpperInvariant();
}

<div class="w-full flex justify-center pb-24">
    <div class="w-full max-w-2xl space-y-8 mx-auto">

        @if (TempData["Success"] is string success)
        {
            <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm px-4 py-3 rounded-xl text-center">
                @success
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-4 py-3 rounded-xl text-center">
                @error
            </div>
        }

        <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8 flex flex-col items-center shadow-lg">
            <div class="w-20 h-20 bg-orange-500/90 rounded-full flex items-center justify-center text-3xl font-extrabold mb-4">
                @initials
            </div>
            <div class="text-2xl font-extrabold text-white tracking-tight text-center">@(Model.FullName ?? Model.Email)</div>
            <div class="flex flex-col items-center gap-2 mt-2">
                <span class="text-gray-400 text-base text-center">@Model.Email</span>
                @if (Model.EmailConfirmed)
                {
                    <span class="inline-flex items-center gap-1 text-xs bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded-full">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                        Verified
                    </span>
                }
                else
                {
                    <span class="inline-flex items-center gap-1 text-xs bg-yellow-500/10 text-yellow-400 border border-yellow-500/20 px-2 py-0.5 rounded-full">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                        Unverified
                    </span>
                }
            </div>
            <span class="inline-block mt-2 text-xs bg-orange-500/10 text-orange-400 border border-orange-500/20 px-3 py-1 rounded-full font-bold uppercase tracking-widest text-center">
                @roleName
            </span>
        </div>

        <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8 shadow-lg">
            <div class="flex items-center justify-between gap-4 flex-wrap">
                <h2 class="font-bold text-white text-lg tracking-tight">Profile Information</h2>
                <div class="flex items-center gap-3">
                    @if (!Model.EmailConfirmed)
                    {
                        <form method="post" action="/profile/email/send-verification" class="inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white font-medium px-5 py-2.5 rounded-lg text-sm transition">
                                Verify Email
                            </button>
                        </form>
                    }
                    <a href="/profile/edit" class="bg-orange-500 hover:bg-orange-600 text-white font-medium px-5 py-2.5 rounded-lg text-sm transition">Edit Profile</a>
                </div>
            </div>

            <div class="mt-6 space-y-4">
                <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-5">
                    <div class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">Full Name</div>
                    <div class="mt-1 text-sm font-semibold text-white">@(Model.FullName ?? "—")</div>
                </div>
                <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-5">
                    <div class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">Email</div>
                    <div class="mt-1 text-sm font-semibold text-white">@(Model.Email ?? "—")</div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-5">
                        <div class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">Date of Birth</div>
                        <div class="mt-1 text-sm font-semibold text-white">@(Model.DateOfBirth?.ToString("MMMM dd, yyyy") ?? "—")</div>
                    </div>
                    <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-5">
                        <div class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">Mobile Number</div>
                        <div class="mt-1 text-sm font-semibold text-white">@(Model.MobileNumber ?? "—")</div>
                    </div>
                    <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-5">
                        <div class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">Sex</div>
                        <div class="mt-1 text-sm font-semibold text-white">@(Model.Sex ?? "—")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8 shadow-lg">
            <h2 class="font-bold text-white mb-4 text-lg tracking-tight">Change Password</h2>
            <form method="post" action="/profile/password" class="space-y-4">
                @Html.AntiForgeryToken()
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1.5">Current Password</label>
                    <input type="password" name="CurrentPassword" required
                        class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition"
                        placeholder="••••••••">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1.5">New Password</label>
                    <input type="password" name="Password" required
                        class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition"
                        placeholder="••••••••">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1.5">Confirm New Password</label>
                    <input type="password" name="PasswordConfirmation" required
                        class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent transition"
                        placeholder="••••••••">
                </div>
                <button type="submit" class="bg-gray-700 hover:bg-gray-600 text-white font-medium px-5 py-2.5 rounded-lg text-sm transition">
                    Update Password
                </button>
            </form>
        </div>

        <div class="bg-[#111114] border border-red-500/20 rounded-[24px] p-8 shadow-lg">
            <h2 class="font-bold text-red-400 mb-1 text-lg tracking-tight">Sign Out</h2>
            <p class="text-gray-500 text-sm mb-4">End your current session and return to the login page.</p>
            <form method="post" action="/logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 font-medium px-5 py-2.5 rounded-lg text-sm transition">
                    Logout
                </button>
            </form>
        </div>

        <!-- Danger Zone -->
        <div class="bg-[#111114] border border-red-500/30 rounded-[24px] p-8 shadow-lg">
            <h2 class="font-bold text-red-400 mb-1 text-lg tracking-tight">Danger Zone</h2>
            <p class="text-gray-500 text-sm mb-4">
                Permanently delete your account.
                @if (User.IsInRole("admin"))
                {
                    <span class="text-red-400">This will also delete your company and all its data.</span>
                }
            </p>
            <button onclick="openDeleteModal()"
                    class="bg-red-600 hover:bg-red-700 text-white font-bold px-5 py-2.5 rounded-lg text-sm transition">
                Delete Account
            </button>
        </div>

    </div>
</div>

<!-- Delete Account Modal -->
<div id="delete-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/70 backdrop-blur-sm">
    <div class="bg-[#111114] border border-red-500/30 rounded-[24px] p-8 w-full max-w-md mx-4 shadow-2xl">

        <!-- Step 1: Warning -->
        <div id="step-warning">
            <div class="w-12 h-12 bg-red-500/10 border border-red-500/20 rounded-2xl flex items-center justify-center text-red-400 mb-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
            </div>
            <h3 class="text-lg font-black text-white mb-2">Delete Account?</h3>
            <p class="text-sm text-gray-400 mb-2">This action is <span class="text-red-400 font-bold">permanent and cannot be undone</span>.</p>
            @if (User.IsInRole("admin"))
            {
                <div class="bg-red-500/10 border border-red-500/20 rounded-xl p-3 mb-4 text-xs text-red-300">
                    ⚠️ As an admin, deleting your account will also permanently delete your company and all associated data including products, materials, schedules, work orders, and reports.
                </div>
            }
            <div class="flex gap-3 mt-6">
                <button onclick="closeDeleteModal()" class="flex-1 px-4 py-2.5 bg-white/[0.03] hover:bg-white/[0.08] text-gray-300 text-sm font-bold rounded-xl border border-white/[0.05] transition">
                    Cancel
                </button>
                <button onclick="sendDeleteCode()" class="flex-1 px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-bold rounded-xl transition">
                    Yes, Delete My Account
                </button>
            </div>
        </div>

        <!-- Step 2: Enter Code -->
        <div id="step-code" class="hidden">
            <div class="w-12 h-12 bg-orange-500/10 border border-orange-500/20 rounded-2xl flex items-center justify-center text-orange-400 mb-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            </div>
            <h3 class="text-lg font-black text-white mb-1">Check your email</h3>
            <p class="text-sm text-gray-400 mb-4">We sent a 6-digit verification code to <span class="text-white font-semibold">@Model.Email</span>. Enter it below to confirm deletion.</p>

            <div id="code-error" class="hidden mb-3 bg-red-500/10 border border-red-500/20 text-red-400 text-xs px-3 py-2 rounded-xl"></div>

            <form method="post" action="/profile/delete" id="delete-form">
                @Html.AntiForgeryToken()
                <div class="mb-4">
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Verification Code</label>
                    <input type="text" name="code" id="delete-code" maxlength="6" required
                           class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white text-center tracking-[0.5em] text-lg font-bold focus:outline-none focus:ring-2 focus:ring-red-500"
                           placeholder="000000" autocomplete="off">
                </div>
                <div class="flex gap-3">
                    <button type="button" onclick="closeDeleteModal()" class="flex-1 px-4 py-2.5 bg-white/[0.03] hover:bg-white/[0.08] text-gray-300 text-sm font-bold rounded-xl border border-white/[0.05] transition">
                        Cancel
                    </button>
                    <button type="submit" class="flex-1 px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-bold rounded-xl transition">
                        Delete Account
                    </button>
                </div>
            </form>

            <button onclick="sendDeleteCode()" class="w-full mt-3 text-xs text-gray-500 hover:text-gray-300 transition">Resend code</button>
        </div>

        <!-- Step 3: Sending -->
        <div id="step-sending" class="hidden text-center py-4">
            <div class="w-10 h-10 mx-auto mb-3 border-2 border-orange-500 border-t-transparent rounded-full animate-spin"></div>
            <p class="text-sm text-gray-400">Sending verification code...</p>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openDeleteModal() {
        document.getElementById('delete-modal').classList.remove('hidden');
        document.getElementById('step-warning').classList.remove('hidden');
        document.getElementById('step-code').classList.add('hidden');
        document.getElementById('step-sending').classList.add('hidden');
    }

    function closeDeleteModal() {
        document.getElementById('delete-modal').classList.add('hidden');
    }

    async function sendDeleteCode() {
        document.getElementById('step-warning').classList.add('hidden');
        document.getElementById('step-code').classList.add('hidden');
        document.getElementById('step-sending').classList.remove('hidden');

        try {
            const token = document.querySelector('input[name=__RequestVerificationToken]').value;
            const res = await fetch('/profile/delete/send-code', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            });
            const data = await res.json();
            if (data.success) {
                document.getElementById('step-sending').classList.add('hidden');
                document.getElementById('step-code').classList.remove('hidden');
            } else {
                alert(data.message || 'Failed to send code. Please try again.');
                closeDeleteModal();
            }
        } catch {
            alert('Failed to send code. Please try again.');
            closeDeleteModal();
        }
    }

    // Close modal on backdrop click
    document.getElementById('delete-modal').addEventListener('click', function(e) {
        if (e.target === this) closeDeleteModal();
    });
</script>
}
