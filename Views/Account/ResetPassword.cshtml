@model PmesCSharp.ViewModels.Account.ResetPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password – PMES</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <style>
        * { font-family: 'Inter', sans-serif; }
        .grid-bg {
            background-image: linear-gradient(rgba(249,115,22,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(249,115,22,0.03) 1px, transparent 1px);
            background-size: 60px 60px;
        }
        .hero-glow { position: fixed; width: 500px; height: 500px; background: radial-gradient(circle, rgba(249,115,22,0.07) 0%, transparent 70%); border-radius: 50%; top: 30%; left: 50%; transform: translate(-50%, -50%); pointer-events: none; }
        html.light body { background-color: #f8fafc; color: #0f172a; }
        html.light nav { border-color: rgba(0,0,0,0.06) !important; }
        html.light h1 { color: #0f172a !important; }
        html.light p { color: #64748b !important; }
        html.light .text-gray-500 { color: #94a3b8 !important; }
        html.light .text-white { color: #0f172a !important; }
        html.light .bg-gray-900\/80 { background-color: rgba(255,255,255,0.95) !important; }
        html.light .border-white\/\[0\.06\] { border-color: rgba(0,0,0,0.08) !important; }
        html.light .bg-gray-800\/80 { background-color: rgba(241,245,249,0.9) !important; }
        html.light .border-white\/\[0\.08\] { border-color: rgba(0,0,0,0.1) !important; }
        html.light input { color: #0f172a !important; }
        html.light .text-gray-400 { color: #64748b !important; }
    </style>
</head>
<body class="bg-[#030712] text-white min-h-screen flex flex-col grid-bg">
    <div class="hero-glow"></div>

    <nav class="border-b border-white/[0.04] px-6 py-4 flex items-center justify-between max-w-7xl mx-auto w-full relative z-10">
        <a href="/login" class="flex items-center gap-2 text-gray-500 hover:text-white transition text-sm group">
            <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Back to Login
        </a>
        <div class="flex items-center gap-3">
            <button onclick="cycleTheme()" title="Toggle theme" class="p-2 rounded-lg text-gray-500 hover:text-white hover:bg-white/5 transition-all duration-200">
                <svg id="t-light" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/></svg>
                <svg id="t-dark" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                <svg id="t-system" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </button>
            <span class="inline-flex items-center justify-center rounded-xl border border-orange-500/20 bg-orange-500/10 p-1.5">
                <img src="/images/LOGO.png" alt="PMES Logo" class="h-6 w-auto object-contain" />
            </span>
            <span class="font-bold text-white text-sm tracking-tight">PMES</span>
        </div>
    </nav>

    <div class="flex-1 flex items-center justify-center px-4 py-12 relative z-10">
        <div class="w-full max-w-md">
            <div class="text-center mb-8" data-aos="fade-down" data-aos-duration="600">
                <div class="inline-flex items-center justify-center rounded-2xl border border-orange-500/20 bg-orange-500/10 p-3 mb-5">
                    <svg class="w-9 h-9 text-orange-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
                    </svg>
                </div>
                <h1 class="text-3xl font-black text-white tracking-tight">Set new password</h1>
                <p class="text-gray-500 text-sm mt-2">Choose a strong password for your account.</p>
            </div>

            <div class="bg-gray-900/80 border border-white/[0.06] rounded-2xl p-8 backdrop-blur-sm shadow-2xl" data-aos="fade-up" data-aos-duration="600" data-aos-delay="100">
                @if (!ViewData.ModelState.IsValid)
                {
                    var globalErrors = ViewData.ModelState[string.Empty]?.Errors;
                    if (globalErrors is not null && globalErrors.Count > 0)
                    {
                        <div class="mb-5 text-red-400 text-sm text-center bg-red-400/10 border border-red-400/20 rounded-xl px-4 py-3">
                            @globalErrors[0].ErrorMessage
                        </div>
                    }
                }
                <form method="post" action="/reset-password" class="space-y-5">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Token" value="@Model.Token" />
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Email address</label>
                        <input name="Email" type="email" required autofocus value="@Model.Email"
                               class="w-full bg-gray-800/80 border border-white/[0.08] text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 placeholder-gray-600 transition-all duration-200"
                               placeholder="you@example.com">
                        <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Email)</span>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">New Password</label>
                        <div class="relative">
                            <input id="password" name="Password" type="password" required
                                   class="w-full bg-gray-800/80 border border-white/[0.08] text-white rounded-xl px-4 py-3 pr-11 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 placeholder-gray-600 transition-all duration-200"
                                   placeholder="••••••••">
                            <button type="button" onclick="togglePwd('password',this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-300 transition">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                            </button>
                        </div>
                        <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Password)</span>
                        <!-- Password Requirements (same as registration) -->
                        <div class="mt-3 space-y-1.5 text-xs">
                            <div class="flex items-center gap-2" id="req-length">
                                <svg class="w-4 h-4 text-gray-500" id="req-length-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span id="req-length-text" class="text-gray-500">At least 8 characters</span>
                            </div>
                            <div class="flex items-center gap-2" id="req-upper">
                                <svg class="w-4 h-4 text-gray-500" id="req-upper-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span id="req-upper-text" class="text-gray-500">One uppercase letter (A-Z)</span>
                            </div>
                            <div class="flex items-center gap-2" id="req-lower">
                                <svg class="w-4 h-4 text-gray-500" id="req-lower-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span id="req-lower-text" class="text-gray-500">One lowercase letter (a-z)</span>
                            </div>
                            <div class="flex items-center gap-2" id="req-digit">
                                <svg class="w-4 h-4 text-gray-500" id="req-digit-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span id="req-digit-text" class="text-gray-500">One digit (0-9)</span>
                            </div>
                            <div class="flex items-center gap-2" id="req-special">
                                <svg class="w-4 h-4 text-gray-500" id="req-special-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                <span id="req-special-text" class="text-gray-500">One special character (!@#$%...)</span>
                            </div>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Confirm New Password</label>
                        <div class="relative">
                            <input id="confirm" name="ConfirmPassword" type="password" required
                                   class="w-full bg-gray-800/80 border border-white/[0.08] text-white rounded-xl px-4 py-3 pr-11 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 placeholder-gray-600 transition-all duration-200"
                                   placeholder="••••••••">
                            <button type="button" onclick="togglePwd('confirm',this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-300 transition">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                            </button>
                        </div>
                        <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.ConfirmPassword)</span>
                        <span id="matchError" class="text-red-400 text-xs mt-1.5 block"></span>
                        <span id="matchSuccess" class="text-emerald-400 text-xs mt-1.5 block hidden">✓ Passwords match</span>
                    </div>
                    <button type="submit" class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold py-3 rounded-xl transition-all duration-200 text-sm shadow-lg shadow-orange-500/20 hover:-translate-y-0.5">
                        Reset Password
                    </button>
                </form>
            </div>

            <p class="text-center text-gray-600 text-sm mt-6" data-aos="fade-up" data-aos-duration="600" data-aos-delay="200">
                Remembered your password?
                <a href="/login" class="text-orange-400 hover:text-orange-300 transition font-medium">Sign in →</a>
            </p>
        </div>
    </div>

    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({ once: true, easing: 'ease-out-cubic' });
        const THEME_KEY = 'pmes-theme';
        const CYCLE = ['system','light','dark'];
        function applyTheme(t) {
            const dark = t === 'dark' || (t === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
            document.documentElement.classList.toggle('light', !dark);
            document.getElementById('t-light').classList.toggle('hidden', t !== 'light');
            document.getElementById('t-dark').classList.toggle('hidden', t !== 'dark');
            document.getElementById('t-system').classList.toggle('hidden', t !== 'system');
        }
        function cycleTheme() {
            const cur = localStorage.getItem(THEME_KEY) || 'system';
            const next = CYCLE[(CYCLE.indexOf(cur) + 1) % CYCLE.length];
            localStorage.setItem(THEME_KEY, next); applyTheme(next);
        }
        function togglePwd(id, btn) {
            const input = document.getElementById(id);
            const show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            btn.innerHTML = show
                ? '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>'
                : '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>';
        }
        applyTheme(localStorage.getItem(THEME_KEY) || 'system');
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
            if ((localStorage.getItem(THEME_KEY) || 'system') === 'system') applyTheme('system');
        });

        // Password requirements checker (for reset password form)
        (function() {
            const passwordInput = document.getElementById('password');
            const confirmInput = document.getElementById('confirm');
            if (!passwordInput) return;

            function updateRequirement(id, ok) {
                const icon = document.getElementById(`req-${id}-icon`);
                const text = document.getElementById(`req-${id}-text`);
                if (!icon || !text) return;
                if (ok) {
                    icon.classList.remove('text-gray-500'); icon.classList.add('text-emerald-500');
                    text.classList.remove('text-gray-500'); text.classList.add('text-emerald-400');
                } else {
                    icon.classList.remove('text-emerald-500'); icon.classList.add('text-gray-500');
                    text.classList.remove('text-emerald-400'); text.classList.add('text-gray-500');
                }
            }

            function checkPassword() {
                const pwd = passwordInput.value;
                updateRequirement('length', pwd.length >= 8);
                updateRequirement('upper', /[A-Z]/.test(pwd));
                updateRequirement('lower', /[a-z]/.test(pwd));
                updateRequirement('digit', /[0-9]/.test(pwd));
                updateRequirement('special', /[^a-zA-Z0-9]/.test(pwd));
                checkMatch();
            }

            function checkMatch() {
                const matchError = document.getElementById('matchError');
                const matchSuccess = document.getElementById('matchSuccess');
                if (!confirmInput.value) { matchError.textContent = ''; matchSuccess.classList.add('hidden'); return; }
                if (passwordInput.value === confirmInput.value) { matchError.textContent = ''; matchSuccess.classList.remove('hidden'); }
                else { matchError.textContent = 'Passwords do not match'; matchSuccess.classList.add('hidden'); }
            }

            passwordInput.addEventListener('input', checkPassword);
            confirmInput.addEventListener('input', checkMatch);
        })();
    </script>
</body>
</html>
