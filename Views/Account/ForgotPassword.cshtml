@model PmesCSharp.ViewModels.Account.ForgotPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password – InkForge Solutions</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style> body { font-family: 'Inter', sans-serif; } </style>
</head>
<body class="bg-gray-950 min-h-screen flex flex-col">

    <nav class="border-b border-gray-800 px-6 py-4 flex items-center justify-between max-w-7xl mx-auto w-full">
        <a href="/login" class="flex items-center gap-2 text-gray-400 hover:text-white transition text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
            Back to Login
        </a>
        <div class="flex items-center gap-2">
            <div class="w-7 h-7 bg-orange-500 rounded-lg flex items-center justify-center font-bold text-xs">IF</div>
            <span class="font-semibold text-white text-sm">InkForge Solutions</span>
        </div>
    </nav>

    <div class="flex-1 flex items-center justify-center px-4 py-12">
        <div class="w-full max-w-md">
            <div class="text-center mb-8">
                <div class="w-12 h-12 bg-orange-500/10 border border-orange-500/20 rounded-xl flex items-center justify-center mx-auto mb-4">
                    <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-white">Forgot your password?</h1>
                <p class="text-gray-400 text-sm mt-2 max-w-sm mx-auto">No problem. Enter your email and we'll send you a reset link.</p>
            </div>

            <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8">

                @if (TempData["Status"] is string status && !string.IsNullOrWhiteSpace(status))
                {
                    <div class="mb-5 bg-green-500/10 border border-green-500/20 text-green-400 text-sm px-4 py-3 rounded-lg flex items-center gap-2">
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        @status
                    </div>
                }

                <form method="post" action="/forgot-password" class="space-y-5">
                    @Html.AntiForgeryToken()

                    <div>
                        <label for="email" class="block text-sm font-medium text-gray-300 mb-1.5">Email address</label>
                        <input id="email" name="Email" type="email" required autofocus value="@Model.Email"
                               class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent placeholder-gray-500 transition"
                               placeholder="you@example.com">
                        <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Email)</span>
                    </div>

                    <button type="submit"
                            class="w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2.5 rounded-lg transition text-sm">
                        Send Reset Link
                    </button>
                </form>
            </div>

            <p class="text-center text-gray-500 text-sm mt-6">
                Remembered your password?
                <a href="/login" class="text-orange-400 hover:text-orange-300 transition font-medium">Sign in →</a>
            </p>
        </div>
    </div>

</body>
</html>
