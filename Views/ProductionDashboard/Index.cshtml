@model List<PmesCSharp.Models.ProductionSchedule>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Production Progress";
    int page = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
    int inProgressCount = ViewBag.InProgressCount;
}

<div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-6">
        <div class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">In Progress Schedules</div>
        <div class="mt-3 text-4xl font-extrabold text-orange-400 tracking-tight">@inProgressCount</div>
    </div>
</div>

<div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h2 class="text-2xl font-bold text-white tracking-tight">Work Order Progress Dashboard</h2>
            <p class="text-sm text-gray-500 mt-1">Showing only <span class="text-orange-300 font-semibold">in-progress</span> schedules.</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="/production/schedules/create" class="px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-orange-900/20">Create Schedule</a>
            <a href="/production/schedules" class="px-6 py-3 bg-white/[0.03] hover:bg-white/[0.08] text-white text-sm font-bold rounded-xl border border-white/[0.05] transition-all">View Schedules</a>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-separate border-spacing-y-3">
            <thead>
                <tr class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">
                    <th class="px-6 py-4">Schedule</th>
                    <th class="px-6 py-4">Product</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4">Started</th>
                    <th class="px-6 py-4">Expected End</th>
                    <th class="px-6 py-4">WO Done</th>
                    <th class="px-6 py-4">Progress</th>
                    <th class="px-6 py-4">Latest QC</th>
                    <th class="px-6 py-4 text-right">Open</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="9" class="px-6 py-10 text-sm text-gray-500">No in-progress schedules.</td></tr>
                }
                @foreach (var s in Model)
                {
                    int total = s.WorkOrders.Count;
                    int done = s.WorkOrders.Count(w => w.Status == "done");
                    int pct = total > 0 ? (int)Math.Round((double)done / total * 100) : 0;

                    var qc = s.QualityChecks.OrderByDescending(q => q.InspectedAt).FirstOrDefault();
                    var qcLabel = qc?.Result?.ToUpperInvariant() ?? "—";
                    var qcClass = qc?.Result switch
                    {
                        "passed" => "text-emerald-300 bg-emerald-500/10 border-emerald-500/20",
                        "failed" => "text-red-300 bg-red-500/10 border-red-500/20",
                        _ => "text-gray-300 bg-white/5 border-white/10"
                    };
                    var statusClass = s.Status switch
                    {
                        "in_progress" => "text-orange-400 bg-orange-500/10 border-orange-500/20",
                        "completed" => "text-emerald-400 bg-emerald-500/10 border-emerald-500/20",
                        _ => "text-gray-300 bg-white/5 border-white/10"
                    };

                    <tr class="bg-white/[0.02] hover:bg-white/[0.05] transition-colors">
                        <td class="px-6 py-5 rounded-l-2xl border-y border-l border-white/[0.05]">
                            <div class="text-sm font-bold text-white">#@s.Id</div>
                            <div class="text-xs text-gray-500">@s.ScheduleDate.ToString("MMM dd, yyyy")</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-sm font-semibold text-gray-200">@(s.Product?.ProductName ?? "—")</div>
                            <div class="text-xs text-gray-600">@(s.Product?.ProductCode ?? "")</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-lg border @statusClass">@s.Status.Replace("_", " ")</span>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-xs text-gray-300 font-semibold">@(s.StartedAt?.ToString("MMM dd, yyyy HH:mm") ?? "—")</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-xs text-gray-300 font-semibold">@(s.ExpectedEndAt?.ToString("MMM dd, yyyy HH:mm") ?? "—")</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-sm font-bold text-white">@done / @total</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="w-44">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="text-xs text-gray-500">@pct%</span>
                                    <span class="text-xs text-gray-600">@done done</span>
                                </div>
                                <div class="h-2 rounded-full bg-white/[0.06] overflow-hidden">
                                    <div class="h-2 rounded-full @(pct >= 100 ? "bg-emerald-500" : "bg-orange-500")" style="width: @pct%"></div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-lg border @qcClass">@qcLabel</span>
                            @if (qc?.InspectedAt is not null)
                            {
                                <div class="text-xs text-gray-600 mt-1">@qc.InspectedAt?.ToString("MMM dd, yyyy HH:mm")</div>
                            }
                        </td>
                        <td class="px-6 py-5 rounded-r-2xl border-y border-r border-white/[0.05] text-right">
                            <a href="/production/schedules/@s.Id" class="px-4 py-2 text-xs font-bold rounded-xl bg-white/[0.03] hover:bg-white/[0.08] border border-white/[0.05] text-white transition-all">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="mt-6 flex items-center gap-2">
            @for (int i = 1; i <= totalPages; i++)
            {
                <a href="/progress?page=@i" class="px-4 py-2 text-xs font-bold rounded-xl @(i == page ? "bg-orange-600 text-white" : "bg-white/[0.03] text-gray-400 hover:bg-white/[0.08]") border border-white/[0.05] transition-all">@i</a>
            }
        </div>
    }
</div>
