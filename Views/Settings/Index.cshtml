@model PmesCSharp.ViewModels.Settings.SettingsViewModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<PmesCSharp.Models.ApplicationUser> UserManager
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Settings";
    var user = await UserManager.GetUserAsync(User);
    var roles = user is null ? new List<string>() : (await UserManager.GetRolesAsync(user)).ToList();
    var roleName = roles.FirstOrDefault() ?? "N/A";
}

@if (TempData["Success"] is string ok)
{
    <div class="mb-6 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm px-4 py-3 rounded-xl">@ok</div>
}

<div class="max-w-2xl space-y-6">

    <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-6 bg-orange-500 rounded-full"></div>
            <h2 class="text-sm font-bold text-gray-500 uppercase tracking-[0.2em]">Appearance</h2>
        </div>

        <form method="post" action="/settings" class="space-y-4">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Theme</label>
                <div class="flex items-center gap-3">
                    <label class="flex items-center gap-3 px-5 py-3 rounded-xl border-2 cursor-pointer transition-all @(Model.Theme == "dark" ? "border-orange-500 bg-orange-500/5" : "border-white/[0.08] bg-white/[0.02] hover:border-white/20")">
                        <input type="radio" name="Theme" value="dark" @(Model.Theme == "dark" ? "checked" : "") class="sr-only" />
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                        <span class="text-sm font-semibold text-white">Dark</span>
                    </label>
                    <label class="flex items-center gap-3 px-5 py-3 rounded-xl border-2 cursor-pointer transition-all @(Model.Theme == "light" ? "border-orange-500 bg-orange-500/5" : "border-white/[0.08] bg-white/[0.02] hover:border-white/20")">
                        <input type="radio" name="Theme" value="light" @(Model.Theme == "light" ? "checked" : "") class="sr-only" />
                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/></svg>
                        <span class="text-sm font-semibold text-white">Light</span>
                    </label>
                </div>
            </div>
            <button type="submit" class="px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-orange-900/20">
                Save Settings
            </button>
        </form>
    </div>

    <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-6 bg-orange-500 rounded-full"></div>
            <h2 class="text-sm font-bold text-gray-500 uppercase tracking-[0.2em]">Account</h2>
        </div>
        <div class="space-y-4">
            @foreach (var item in new[]
            {
                new { Label = "Full Name", Value = user?.FullName ?? "—" },
                new { Label = "Email", Value = user?.Email ?? "—" },
                new { Label = "Role", Value = roleName },
                new { Label = "Email Verified", Value = user?.EmailConfirmed == true ? "Yes" : "No" },
            })
            {
                <div class="flex items-center justify-between py-3 border-b border-white/[0.04] last:border-0">
                    <span class="text-sm text-gray-500">@item.Label</span>
                    <span class="text-sm font-semibold text-white">@item.Value</span>
                </div>
            }
        </div>
        <div class="mt-5">
            <a href="/profile" class="inline-flex items-center gap-2 text-sm text-orange-400 hover:text-orange-300 transition font-medium">
                Edit Profile
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
        </div>
    </div>

    <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-6 bg-orange-500 rounded-full"></div>
            <h2 class="text-sm font-bold text-gray-500 uppercase tracking-[0.2em]">Quick Links</h2>
        </div>
        <div class="space-y-2">
            @foreach (var link in new[]
            {
                new { Href = "/profile", Label = "My Profile", Icon = "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" },
                new { Href = "/company/profile", Label = "Company Profile", Icon = "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
                new { Href = "/subscription", Label = "Subscription", Icon = "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
            })
            {
                <a href="@link.Href" class="flex items-center justify-between p-4 rounded-xl hover:bg-white/5 transition-colors group">
                    <div class="flex items-center gap-3">
                        <div class="text-gray-500 group-hover:text-orange-500 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="@link.Icon"/></svg>
                        </div>
                        <span class="text-sm font-semibold text-gray-300 group-hover:text-white transition-colors">@link.Label</span>
                    </div>
                    <svg class="w-4 h-4 text-gray-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
            }
        </div>
    </div>

</div>

@section Scripts {
<script>
    document.querySelectorAll('input[name="Theme"]').forEach(function(el) {
        el.addEventListener('change', function() {
            var isLight = this.value === 'light';
            document.documentElement.classList.toggle('theme-light', isLight);
            try { localStorage.setItem('pmes-theme', this.value); } catch(e) {}
            // Update label styles
            document.querySelectorAll('label:has(input[name="Theme"])').forEach(function(lbl) {
                var inp = lbl.querySelector('input');
                var selected = inp && inp.checked;
                lbl.classList.toggle('border-orange-500', selected);
                lbl.classList.toggle('bg-orange-500/5', selected);
                lbl.classList.toggle('border-white/[0.08]', !selected);
                lbl.classList.toggle('bg-white/[0.02]', !selected);
            });
        });
    });
</script>
}
