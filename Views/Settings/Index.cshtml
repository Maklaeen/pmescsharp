@model PmesCSharp.ViewModels.Settings.SettingsViewModel
@{
    Layout = (ViewData["Layout"] as string) ?? "_AdminLayout";
    ViewData["Title"] = "Settings";
}

<div class="settings-card bg-gray-900/40 border border-gray-800/50 rounded-2xl p-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <div class="text-xs font-bold text-gray-500 uppercase tracking-[0.2em]">System</div>
            <h2 class="text-xl font-extrabold text-white tracking-tight mt-1">Settings</h2>
        </div>
    </div>

    @if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="mb-6 text-emerald-400 text-sm bg-emerald-400/10 border border-emerald-400/20 rounded-lg px-4 py-2">@ok</div>
    }

    <form method="post" action="/settings" class="space-y-6">
        @Html.AntiForgeryToken()

        <div>
            <div class="text-[11px] font-bold text-gray-600 uppercase tracking-wider mb-3">Appearance</div>
            <div class="flex items-center gap-3">
                <label class="flex items-center gap-2 px-4 py-3 rounded-xl bg-white/[0.03] border border-white/[0.06] cursor-pointer">
                    <input type="radio" name="Theme" value="dark" @(Model.Theme == "dark" ? "checked" : "") class="accent-orange-500" />
                    <span class="text-sm font-semibold text-gray-200">Dark</span>
                </label>
                <label class="flex items-center gap-2 px-4 py-3 rounded-xl bg-white/[0.03] border border-white/[0.06] cursor-pointer">
                    <input type="radio" name="Theme" value="light" @(Model.Theme == "light" ? "checked" : "") class="accent-orange-500" />
                    <span class="text-sm font-semibold text-gray-200">Light</span>
                </label>
            </div>
            <span class="text-red-400 text-xs mt-2 block">@Html.ValidationMessageFor(m => m.Theme)</span>
        </div>

        <div class="pt-2">
            <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2.5 px-6 rounded-lg transition text-sm">
                Save Settings
            </button>
        </div>
    </form>
</div>

@section Scripts {
<style>
    body.theme-light .settings-card {
        background: rgba(255, 255, 255, 0.9) !important;
        border-color: rgba(0, 0, 0, 0.08) !important;
    }
    body.theme-light .settings-card h2,
    body.theme-light .settings-card .text-white {
        color: #111827 !important;
    }
    body.theme-light .settings-card .text-gray-500,
    body.theme-light .settings-card .text-gray-600,
    body.theme-light .settings-card .text-gray-400,
    body.theme-light .settings-card .text-gray-200 {
        color: #4b5563 !important;
    }
    body.theme-light .settings-card label {
        background: rgba(0, 0, 0, 0.03) !important;
        border-color: rgba(0, 0, 0, 0.08) !important;
    }
</style>
<script>
    (function () {
        function applyTheme(theme) {
            try { localStorage.setItem('theme', theme); } catch (e) { }
            document.body.classList.toggle('theme-light', theme === 'light');
        }

        // Ensure theme is applied on load based on the current setting.
        applyTheme('@Model.Theme');

        document.querySelectorAll('input[name="Theme"]').forEach(function (el) {
            el.addEventListener('change', function () {
                applyTheme(this.value);
            });
        });
    })();
</script>
}
