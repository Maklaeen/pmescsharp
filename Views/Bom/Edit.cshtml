@model PmesCSharp.ViewModels.Bom.BomFormViewModel
@using PmesCSharp.Models
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit BOM Line";
    var products = ViewBag.Products as List<Product> ?? [];
    var materials = ViewBag.Materials as List<Material> ?? [];
    var bomId = ViewBag.BomId;
}

<div class="max-w-3xl">
    <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
        <div class="mb-8">
            <h2 class="text-2xl font-bold text-white tracking-tight">Edit BOM Line</h2>
            <p class="text-sm text-gray-500 mt-1">Update material requirement for this product.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            var errors = ViewData.ModelState.Values.SelectMany(v => v.Errors).ToList();
            if (errors.Count > 0)
            {
                <div class="mb-6 p-4 rounded-2xl bg-red-500/10 border border-red-500/20 text-sm text-red-300">
                    @errors[0].ErrorMessage
                </div>
            }
        }

        <form method="post" action="/admin/bom/@bomId/edit" class="space-y-6">
            @Html.AntiForgeryToken()

            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Product</label>
                <select name="ProductId" class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500">
                    <option value="">Select product…</option>
                    @foreach (var p in products)
                    {
                        if (Model.ProductId == p.Id) { <option value="@p.Id" selected>@p.ProductName (@p.ProductCode)</option> }
                        else { <option value="@p.Id">@p.ProductName (@p.ProductCode)</option> }
                    }
                </select>
            </div>

            <div>
                <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Material</label>
                <select name="MaterialId" class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500">
                    <option value="">Select material…</option>
                    @foreach (var m in materials)
                    {
                        if (Model.MaterialId == m.Id) { <option value="@m.Id" selected>@m.MaterialName (@m.MaterialCode)</option> }
                        else { <option value="@m.Id">@m.MaterialName (@m.MaterialCode)</option> }
                    }
                </select>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Quantity Required (per 1 unit)</label>
                    <input type="number" step="0.0001" min="0.0001" name="QuantityRequired" value="@Model.QuantityRequired"
                        class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Unit (optional override)</label>
                    <input type="text" name="Unit" value="@Model.Unit"
                        class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500"
                        placeholder="pcs">
                    <div class="mt-2 text-xs text-gray-600">Leave blank to use the material unit.</div>
                </div>
            </div>

            <div class="flex items-center justify-end gap-3 pt-4 border-t border-white/[0.05]">
                <a href="/admin/bom" class="px-6 py-3 bg-white/[0.03] hover:bg-white/[0.08] text-white text-sm font-bold rounded-xl border border-white/[0.05] transition-all">Back</a>
                <button type="submit" class="px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-orange-900/20">Save Changes</button>
            </div>
        </form>
    </div>
</div>
