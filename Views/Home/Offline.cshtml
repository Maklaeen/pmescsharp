@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>No Connection – PMES</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style> body { font-family: 'Plus Jakarta Sans', sans-serif; } </style>
</head>
<body class="bg-[#0c0c0e] min-h-screen flex flex-col">

    <nav class="border-b border-white/[0.05] px-6 py-4 flex items-center justify-between max-w-7xl mx-auto w-full">
        <a href="javascript:history.back()" class="flex items-center gap-2 text-gray-500 hover:text-white transition text-sm font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
            Go Back
        </a>
        <img src="/images/LOGO.png" alt="PMES" class="h-7 w-auto object-contain opacity-60">
    </nav>

    <div class="flex-1 flex items-center justify-center px-4 py-16">
        <div class="w-full max-w-md text-center">

            <div class="w-20 h-20 bg-gray-500/10 border border-gray-500/20 rounded-3xl flex items-center justify-center mx-auto mb-6">
                <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 3l8.735 8.735m0 0a6.003 6.003 0 007.54-7.54m-7.54 7.54L3 21M17.25 3.75L21 7.5m-3.75 0L21 3.75M3.75 20.25L7.5 21m-3.75-.75L3.75 17.25"/>
                </svg>
            </div>

            <div class="inline-flex items-center gap-2 bg-gray-500/10 border border-gray-500/20 rounded-full px-3 py-1 mb-4">
                <div class="w-1.5 h-1.5 bg-gray-500 rounded-full"></div>
                <span class="text-[11px] font-bold text-gray-400 uppercase tracking-wider">No Connection</span>
            </div>

            <h1 class="text-2xl font-extrabold text-white tracking-tight">You're offline</h1>
            <p class="text-gray-400 text-sm mt-3 leading-relaxed max-w-sm mx-auto">
                It looks like you've lost your internet connection or the server is unreachable. Check your network and try again.
            </p>

            <div class="mt-8 flex items-center justify-center gap-3">
                <button onclick="window.location.reload()"
                        class="bg-orange-600 hover:bg-orange-700 text-white font-semibold px-6 py-2.5 rounded-xl transition text-sm shadow-lg shadow-orange-900/20">
                    Retry
                </button>
                <a href="/admin"
                   class="border border-white/[0.08] hover:border-white/20 text-gray-300 hover:text-white font-semibold px-5 py-2.5 rounded-xl transition text-sm">
                    Go to Dashboard
                </a>
            </div>

            <div id="online-status" class="mt-6 hidden">
                <div class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-3 py-1.5">
                    <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></div>
                    <span class="text-xs font-semibold text-emerald-400">Connection restored — reloading…</span>
                </div>
            </div>

            <p class="mt-8 text-xs text-gray-700">
                If the problem persists, contact your network administrator.
            </p>
        </div>
    </div>

    <script>
        window.addEventListener('online', function () {
            document.getElementById('online-status').classList.remove('hidden');
            setTimeout(function () { window.location.reload(); }, 1500);
        });
    </script>

</body>
</html>
