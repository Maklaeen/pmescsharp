@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PMES — Production & Manufacturing Execution System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <style>
        * { font-family: 'Inter', sans-serif; }

        /* Gradient text */
        .gradient-text {
            background: linear-gradient(135deg, #f97316, #fb923c, #fdba74);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Animated gradient background */
        .hero-glow {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(249,115,22,0.12) 0%, transparent 70%);
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation: pulse-glow 4s ease-in-out infinite;
            pointer-events: none;
        }

        @@keyframes pulse-glow {
            0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
            50% { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
        }

        /* Floating animation */
        .float {
            animation: float 6s ease-in-out infinite;
        }

        @@keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-12px); }
        }

        /* Shimmer effect on cards */
        .shimmer {
            position: relative;
            overflow: hidden;
        }
        .shimmer::after {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 60%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent);
            animation: shimmer 3s infinite;
        }
        @@keyframes shimmer {
            0% { left: -100%; }
            100% { left: 200%; }
        }

        /* Progress bar animation */
        .progress-bar {
            animation: progress 2s ease-out forwards;
            width: 0;
        }
        @@keyframes progress {
            to { width: 66.666%; }
        }

        /* Typewriter cursor */
        .cursor::after {
            content: '|';
            animation: blink 1s step-end infinite;
            color: #f97316;
        }
        @@keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }

        /* Navbar scroll effect */
        .navbar-scrolled {
            background: rgba(3, 7, 18, 0.95) !important;
            border-color: rgba(249,115,22,0.15) !important;
        }

        /* Feature card hover */
        .feature-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .feature-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(249,115,22,0.08);
        }

        /* Stat counter animation */
        @@keyframes count-up {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .stat-value {
            animation: count-up 0.6s ease-out forwards;
        }

        /* Smooth scroll */
        html { scroll-behavior: smooth; }

        /* Grid background */
        .grid-bg {
            background-image:
                linear-gradient(rgba(249,115,22,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(249,115,22,0.03) 1px, transparent 1px);
            background-size: 60px 60px;
        }

        /* Light mode overrides */
        html.light body { background-color: #f8fafc; color: #0f172a; }
        html.light #navbar { background: rgba(248,250,252,0.85) !important; border-color: rgba(0,0,0,0.06) !important; }
        html.light .navbar-scrolled { background: rgba(248,250,252,0.97) !important; }
        html.light nav a { color: #475569; }
        html.light nav a:hover { color: #0f172a; }
        html.light .hero-glow { background: radial-gradient(circle, rgba(249,115,22,0.08) 0%, transparent 70%); }
        html.light .grid-bg {
            background-image:
                linear-gradient(rgba(249,115,22,0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(249,115,22,0.05) 1px, transparent 1px);
        }
        html.light h1, html.light h2, html.light h3 { color: #0f172a; }
        html.light p { color: #475569; }
        html.light .text-gray-400 { color: #64748b !important; }
        html.light .text-gray-500 { color: #94a3b8 !important; }
        html.light .text-gray-600 { color: #64748b !important; }
        html.light .text-white { color: #0f172a !important; }
        html.light .bg-gray-900\/60, html.light .bg-gray-900\/80, html.light .bg-gray-900\/90 { background-color: rgba(255,255,255,0.9) !important; }
        html.light .bg-gray-900\/40 { background-color: rgba(255,255,255,0.7) !important; }
        html.light .bg-gray-950\/50, html.light .bg-gray-950\/60 { background-color: rgba(241,245,249,0.8) !important; }
        html.light .border-white\/\[0\.04\], html.light .border-white\/\[0\.05\], html.light .border-white\/\[0\.06\], html.light .border-white\/\[0\.07\] { border-color: rgba(0,0,0,0.08) !important; }
        html.light .feature-card { background-color: rgba(255,255,255,0.9) !important; border-color: rgba(0,0,0,0.08) !important; }
        html.light .feature-card:hover { border-color: rgba(249,115,22,0.3) !important; }
        html.light footer { border-color: rgba(0,0,0,0.08) !important; }
        html.light footer p, html.light footer span, html.light footer a { color: #94a3b8 !important; }
        html.light footer a:hover { color: #0f172a !important; }
    </style>
</head>
<body class="bg-[#030712] text-white overflow-x-hidden">

    {{-- Navbar --}}
    <nav id="navbar" class="fixed inset-x-0 top-0 z-50 border-b border-white/[0.04] bg-[#030712]/80 backdrop-blur-xl px-6 py-4 transition-all duration-300">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <a href="#home" class="flex items-center gap-3 group">
                <span class="inline-flex items-center justify-center rounded-xl border border-orange-500/20 bg-orange-500/10 p-2 group-hover:bg-orange-500/20 transition-all duration-300">
                    <img src="/images/LOGO.png" alt="PMES Logo" class="h-7 w-auto object-contain" />
                </span>
                <span class="font-bold text-white text-sm hidden sm:block tracking-tight">PMES</span>
            </a>

            <div class="hidden md:flex items-center gap-1">
                @foreach (var link in new[] { ("#home", "Home"), ("#features", "Features"), ("#overview", "Overview") })
                {
                    <a href="@link.Item1" class="px-4 py-2 text-sm font-medium text-gray-400 hover:text-white hover:bg-white/5 rounded-lg transition-all duration-200">@link.Item2</a>
                }
            </div>

            <div class="flex items-center gap-3">
                <div class="relative" id="theme-menu-wrapper">
                    <button id="theme-toggle" onclick="toggleThemeMenu()"
                            class="p-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all duration-200"
                            title="Toggle theme">
                      
                        <svg id="icon-light" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
                        </svg>
                    
                        <svg id="icon-dark" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                        </svg>
                      
                        <svg id="icon-system" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                    </button>
                    <div id="theme-menu" class="hidden absolute right-0 mt-2 w-36 bg-gray-900 border border-white/[0.08] rounded-xl shadow-xl overflow-hidden z-50">
                        <button onclick="setTheme('light')" class="theme-option w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition" data-theme="light">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/></svg>
                            Light
                        </button>
                        <button onclick="setTheme('dark')" class="theme-option w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition" data-theme="dark">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                            Dark
                        </button>
                        <button onclick="setTheme('system')" class="theme-option w-full flex items-center gap-2.5 px-4 py-2.5 text-sm text-gray-300 hover:bg-white/5 hover:text-white transition" data-theme="system">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            System
                        </button>
                    </div>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/dashboard" class="text-sm font-medium text-gray-300 hover:text-white transition px-4 py-2 hover:bg-white/5 rounded-lg">Dashboard</a>
                }
                else
                {
                    <a href="/login" class="text-sm font-medium text-gray-400 hover:text-white transition px-4 py-2 hover:bg-white/5 rounded-lg">Sign In</a>
                    <a href="/register" class="text-sm font-semibold bg-orange-500 hover:bg-orange-600 text-white px-5 py-2 rounded-lg transition-all duration-200 shadow-lg shadow-orange-500/20">
                        Get Started
                    </a>
                }
            </div>
        </div>
    </nav>

    <section id="home" class="relative min-h-screen flex items-center grid-bg">
        <div class="hero-glow"></div>

        <div class="relative max-w-7xl mx-auto px-6 pt-24 pb-16 w-full">
            <div class="max-w-4xl mx-auto text-center">

                <div data-aos="fade-down" data-aos-duration="600"
                     class="inline-flex items-center gap-2 bg-orange-500/10 border border-orange-500/20 text-orange-400 text-xs font-semibold px-4 py-2 rounded-full mb-8">
                    <span class="w-1.5 h-1.5 bg-orange-400 rounded-full animate-pulse"></span>
                    Production &amp; Manufacturing Execution System
                </div>

                <h1 data-aos="fade-up" data-aos-duration="700" data-aos-delay="100"
                    class="text-5xl md:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight mb-6">
                    Run production<br>
                    <span class="gradient-text">with clarity.</span>
                </h1>
                 <h1 data-aos="fade-up" data-aos-duration="700" data-aos-delay="100"
                    class="text-5xl md:text-6xl lg:text-7xl font-black leading-[1.05] tracking-tight mb-6">
                    Run production<br>
                    <span class="gradient-text">with clarity.</span>
                </h1>
                <p data-aos="fade-up" data-aos-duration="700" data-aos-delay="200"
                   class="text-gray-400 text-lg md:text-xl mx-auto max-w-2xl leading-relaxed mb-10">
                    A web-based MES for custom manufacturing businesses — manage production schedules,
                    track material requirements, execute work orders, compute costs, and control quality all in one place.
                </p>

                <div data-aos="fade-up" data-aos-duration="700" data-aos-delay="300"
                     class="flex items-center justify-center gap-4 flex-wrap">
                    <a href="/register"
                       class="group relative bg-orange-500 hover:bg-orange-600 text-white font-semibold px-8 py-3.5 rounded-xl transition-all duration-300 text-sm shadow-xl shadow-orange-500/25 hover:shadow-orange-500/40 hover:-translate-y-0.5">
                        Get Started Free
                        <span class="ml-2 group-hover:translate-x-1 inline-block transition-transform duration-200">→</span>
                    </a>
                    <a href="#features"
                       class="border border-white/10 hover:border-white/20 text-gray-300 hover:text-white font-medium px-8 py-3.5 rounded-xl transition-all duration-300 text-sm hover:bg-white/5 hover:-translate-y-0.5">
                        See Features
                    </a>
                </div>
            </div>

            <div data-aos="fade-up" data-aos-duration="900" data-aos-delay="400"
                 class="relative mt-20 max-w-4xl mx-auto float">
                <div class="absolute -inset-8 bg-orange-500/5 blur-3xl rounded-full"></div>
                <div class="absolute -inset-1 bg-gradient-to-b from-orange-500/10 to-transparent rounded-3xl blur-xl"></div>

                <div class="relative bg-gray-900/90 border border-white/[0.07] rounded-2xl overflow-hidden shadow-2xl backdrop-blur-sm">
                    <div class="flex items-center justify-between px-5 py-3.5 border-b border-white/[0.05] bg-gray-950/50">
                        <div class="flex items-center gap-1.5">
                            <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
                            <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
                            <span class="w-3 h-3 rounded-full bg-emerald-500/70"></span>
                        </div>
                        <div class="text-[11px] font-bold text-gray-500 tracking-[0.2em] uppercase">PMES Dashboard</div>
                        <div class="w-16"></div>
                    </div>

                    <div class="p-6">
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-5">
                            @foreach (var (card, idx) in new[]
                            {
                                new { Label = "Work Orders", Value = "18", Sub = "↑ 6% this week", Color = "text-emerald-400", Bg = "bg-emerald-500/10", Border = "border-emerald-500/20" },
                                new { Label = "Material Alerts", Value = "3", Sub = "Needs review", Color = "text-orange-400", Bg = "bg-orange-500/10", Border = "border-orange-500/20" },
                                new { Label = "Schedules", Value = "7", Sub = "Due this month", Color = "text-blue-400", Bg = "bg-blue-500/10", Border = "border-blue-500/20" },
                                new { Label = "QC Pass Rate", Value = "96%", Sub = "Stable", Color = "text-emerald-400", Bg = "bg-emerald-500/10", Border = "border-emerald-500/20" },
                            }.Select((c, i) => (c, i)))
                            {
                                <div class="shimmer @card.Bg border @card.Border rounded-xl p-4">
                                    <div class="text-[11px] text-gray-500 mb-2">@card.Label</div>
                                    <div class="text-2xl font-black text-white stat-value">@card.Value</div>
                                    <div class="text-[11px] @card.Color mt-1">@card.Sub</div>
                                </div>
                            }
                        </div>

                        <div class="bg-gray-950/60 border border-white/[0.05] rounded-xl p-4">
                            <div class="flex items-center justify-between mb-3">
                                <div class="text-xs font-semibold text-gray-300">Production Progress</div>
                                <div class="text-[11px] text-gray-500 bg-gray-800 px-2 py-0.5 rounded-full">Today</div>
                            </div>
                            <div class="h-2 rounded-full bg-white/[0.05] overflow-hidden">
                                <div class="progress-bar h-full bg-gradient-to-r from-orange-500 to-orange-400 rounded-full"></div>
                            </div>
                            <div class="flex items-center justify-between mt-2">
                                <div class="text-[11px] text-gray-500">On-track vs plan</div>
                                <div class="text-[11px] text-orange-400 font-semibold">67%</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="features" class="max-w-7xl mx-auto px-6 py-24">
        <div class="text-center mb-16" data-aos="fade-up" data-aos-duration="600">
            <div class="inline-flex items-center gap-2 bg-orange-500/10 border border-orange-500/20 text-orange-400 text-xs font-semibold px-4 py-2 rounded-full mb-4">
                Powerful Features
            </div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mt-3 tracking-tight">
                Everything you need<br>
                <span class="gradient-text">to run production</span>
            </h2>
            <p class="text-gray-400 mt-5 max-w-2xl mx-auto text-lg">
                Core tools to plan, execute, and control manufacturing operations with less manual work.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var (feature, i) in new[]
            {
                new { Icon = "🗓️", Title = "Production Planning", Desc = "Schedule production runs based on demand, capacity, and due dates.", Delay = 0 },
                new { Icon = "📦", Title = "Material Requirements", Desc = "Auto-compute material needs and detect shortages before production starts.", Delay = 100 },
                new { Icon = "🔧", Title = "Work Order Management", Desc = "Generate and monitor work orders from schedule to completion.", Delay = 200 },
                new { Icon = "💰", Title = "Production Costing", Desc = "Compute cost per batch and generate cost summaries automatically.", Delay = 0 },
                new { Icon = "✅", Title = "Quality Control", Desc = "Record and track inspection results for every production output.", Delay = 100 },
                new { Icon = "👥", Title = "Role-Based Access", Desc = "Admin, Planner, Inventory, Operator, and QC roles with proper permissions.", Delay = 200 },
            }.Select((f, idx) => (f, idx)))
            {
                <div class="feature-card shimmer bg-gray-900/60 border border-white/[0.06] rounded-2xl p-7 hover:border-orange-500/30 hover:bg-gray-900/80 cursor-default"
                     data-aos="fade-up" data-aos-duration="600" data-aos-delay="@feature.Delay">
                    <div class="text-4xl mb-5">@feature.Icon</div>
                    <h3 class="font-bold text-white text-lg mb-2">@feature.Title</h3>
                    <p class="text-gray-400 text-sm leading-relaxed">@feature.Desc</p>
                </div>
            }
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 pb-24">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            @foreach (var (stat, i) in new[]
            {
                new { Value = "6", Label = "Roles Supported", Suffix = "+", Sub = "Admin, Planner, Inventory, Operator, QC, Superadmin" },
                new { Value = "5", Label = "Core Modules", Suffix = "+", Sub = "Scheduling, Work Orders, Inventory, Costing, QC" },
                new { Value = "MRP", Label = "Auto-Computed", Suffix = "", Sub = "Material requirements computed from BOM" },
                new { Value = "BOM", Label = "Driven Costing", Suffix = "", Sub = "Cost per unit calculated from materials + labor" },
            }.Select((s, idx) => (s, idx)))
            {
                <div class="p-6 bg-gray-900/40 border border-white/[0.05] rounded-2xl hover:border-orange-500/20 transition-all duration-300"
                     data-aos="zoom-in" data-aos-duration="500" data-aos-delay="@(i * 100)">
                    <div class="text-3xl md:text-4xl font-black gradient-text mb-1">@stat.Value@stat.Suffix</div>
                    <div class="text-white text-sm font-semibold">@stat.Label</div>
                    <div class="text-gray-600 text-xs mt-1 leading-relaxed">@stat.Sub</div>
                </div>
            }
        </div>
    </section>

    <section id="overview" class="max-w-7xl mx-auto px-6 pb-24">
        <div class="relative overflow-hidden bg-gradient-to-br from-orange-500/10 via-gray-900/60 to-gray-950 border border-orange-500/20 rounded-3xl p-12 md:p-16 text-center"
             data-aos="fade-up" data-aos-duration="700">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-1 bg-gradient-to-r from-transparent via-orange-500/50 to-transparent"></div>
            <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-96 h-96 bg-orange-500/5 blur-3xl rounded-full pointer-events-none"></div>

            <div class="relative">
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white tracking-tight">
                    From schedule to delivery —<br>
                    <span class="gradient-text">PMES handles the rest.</span>
                </h2>
                <p class="text-gray-400 mt-5 max-w-2xl mx-auto text-lg">
                    Plan production batches, auto-compute material needs via BOM, assign work orders to operators,
                    track costs, and record QC results — all in one integrated system.
                </p>
                <div class="mt-10 flex items-center justify-center gap-4 flex-wrap">
                    <a href="/register"
                       class="bg-orange-500 hover:bg-orange-600 text-white font-semibold px-10 py-4 rounded-xl transition-all duration-300 text-sm shadow-xl shadow-orange-500/25 hover:shadow-orange-500/40 hover:-translate-y-0.5">
                        Get Started Free →
                    </a>
                    <a href="/login"
                       class="border border-white/10 hover:border-white/20 text-gray-300 hover:text-white font-medium px-10 py-4 rounded-xl transition-all duration-300 text-sm hover:bg-white/5 hover:-translate-y-0.5">
                        Sign In
                    </a>
                </div>
            </div>
        </div>
    </section>

    <footer class="border-t border-white/[0.04] px-6 py-8">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-3 text-sm text-gray-600">
            <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center rounded-lg border border-orange-500/20 bg-orange-500/10 p-1.5">
                    <img src="/images/LOGO.png" alt="PMES Logo" class="h-5 w-auto object-contain" />
                </span>
                <p>&copy; @DateTime.Now.Year PMES — Production &amp; Manufacturing Execution System</p>
            </div>
            <div class="flex items-center gap-4">
                <a href="/privacy" class="hover:text-white transition">Privacy Policy</a>
                <span>All rights reserved.</span>
            </div>
        </div>
    </footer>

    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({ once: true, easing: 'ease-out-cubic' });

        // Navbar scroll effect
        const navbar = document.getElementById('navbar');
        window.addEventListener('scroll', () => {
            navbar.classList.toggle('navbar-scrolled', window.scrollY > 50);
        });

        // Theme system
        const THEME_KEY = 'pmes-theme';

        function applyTheme(theme) {
            const isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
            document.documentElement.classList.toggle('light', !isDark);
            document.getElementById('icon-light').classList.toggle('hidden', theme !== 'light');
            document.getElementById('icon-dark').classList.toggle('hidden', theme !== 'dark');
            document.getElementById('icon-system').classList.toggle('hidden', theme !== 'system');
            document.querySelectorAll('.theme-option').forEach(btn => {
                const active = btn.dataset.theme === theme;
                btn.classList.toggle('text-orange-400', active);
                btn.classList.toggle('text-gray-300', !active);
            });
        }

        function setTheme(theme) {
            localStorage.setItem(THEME_KEY, theme);
            applyTheme(theme);
            document.getElementById('theme-menu').classList.add('hidden');
        }

        function toggleThemeMenu() {
            document.getElementById('theme-menu').classList.toggle('hidden');
        }

        // Close menu on outside click
        document.addEventListener('click', (e) => {
            if (!document.getElementById('theme-menu-wrapper').contains(e.target)) {
                document.getElementById('theme-menu').classList.add('hidden');
            }
        });

        // Init theme on load
        const saved = localStorage.getItem(THEME_KEY) || 'system';
        applyTheme(saved);

        // Watch system preference changes
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
            if ((localStorage.getItem(THEME_KEY) || 'system') === 'system') applyTheme('system');
        });
    </script>

</body>
</html>
