@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Access Denied – PMES</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style> body { font-family: 'Plus Jakarta Sans', sans-serif; } </style>
</head>
<body class="bg-[#0c0c0e] min-h-screen flex flex-col">

    <nav class="border-b border-white/[0.05] px-6 py-4 flex items-center justify-between max-w-7xl mx-auto w-full">
        <a href="javascript:history.back()" class="flex items-center gap-2 text-gray-500 hover:text-white transition text-sm font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
            Go Back
        </a>
        <img src="/images/LOGO.png" alt="PMES" class="h-7 w-auto object-contain opacity-60">
    </nav>

    <div class="flex-1 flex items-center justify-center px-4 py-16">
        <div class="w-full max-w-md text-center">

            <div class="w-20 h-20 bg-orange-500/10 border border-orange-500/20 rounded-3xl flex items-center justify-center mx-auto mb-6">
                <svg class="w-10 h-10 text-orange-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
                </svg>
            </div>

            <div class="inline-flex items-center gap-2 bg-orange-500/10 border border-orange-500/20 rounded-full px-3 py-1 mb-4">
                <span class="text-[11px] font-bold text-orange-400 uppercase tracking-wider">403 Access Denied</span>
            </div>

            <h1 class="text-2xl font-extrabold text-white tracking-tight">You don't have access</h1>
            <p class="text-gray-400 text-sm mt-3 leading-relaxed max-w-sm mx-auto">
                You don't have permission to view this page. If you think this is a mistake, contact your administrator.
            </p>

            <div class="mt-8 flex items-center justify-center gap-3">
                <a href="javascript:history.back()"
                   class="border border-white/[0.08] hover:border-white/20 text-gray-300 hover:text-white font-semibold px-5 py-2.5 rounded-xl transition text-sm">
                    Go Back
                </a>
                <a href="/admin" class="bg-orange-600 hover:bg-orange-700 text-white font-semibold px-5 py-2.5 rounded-xl transition text-sm shadow-lg shadow-orange-900/20">
                    Go to Dashboard
                </a>
            </div>

            <p class="mt-8 text-xs text-gray-700">
                Your current role may not have permission for this action.
            </p>
        </div>
    </div>

</body>
</html>
