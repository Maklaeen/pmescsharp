@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Processing Payment";
    var linkId = ViewBag.LinkId as string ?? "";
    var plan = ViewBag.Plan as string ?? "";
    var cycle = ViewBag.Cycle as string ?? "";
    var email = ViewBag.Email as string ?? "";
}

<div class="flex items-center justify-center min-h-[70vh]">
    <div class="text-center max-w-md w-full">

        <div id="state-checking">
            <div class="w-20 h-20 mx-auto mb-6 relative">
                <div class="absolute inset-0 rounded-full border-4 border-orange-500/20"></div>
                <div class="absolute inset-0 rounded-full border-4 border-t-orange-500 animate-spin"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                    <svg class="w-8 h-8 text-orange-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
                    </svg>
                </div>
            </div>
            <h2 class="text-2xl font-black text-white tracking-tight mb-2">Verifying Payment</h2>
            <p class="text-gray-500 text-sm mb-2">Please wait while we confirm your payment with PayMongo.</p>
            <p class="text-gray-600 text-xs">This page will automatically redirect once payment is confirmed.</p>

            <div class="mt-8 bg-[#111114] border border-white/[0.05] rounded-2xl p-5">
                <div class="flex items-center justify-between text-sm mb-3">
                    <span class="text-gray-500">Plan</span>
                    <span class="text-white font-bold">@plan</span>
                </div>
                <div class="flex items-center justify-between text-sm mb-3">
                    <span class="text-gray-500">Billing</span>
                    <span class="text-white font-bold">@cycle</span>
                </div>
                 <div class="flex items-center justify-between text-sm">
                     <span class="text-gray-500">Amount</span>
                     <span class="text-white font-bold">(see PayMongo)</span>
                 </div>
                 <div class="mt-6 text-center">
                     <a href="/subscription/success?plan=@plan&cycle=@cycle&email=@email" class="inline-block px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all mt-2">
                         Activate Subscription
                     </a>
                     <div class="text-xs text-gray-500 mt-2">If you already paid but are not redirected, click here to activate your subscription.</div>
                 </div>
            </div>

            <div class="mt-6 flex items-center justify-center gap-2 text-xs text-gray-600">
                <div class="w-1.5 h-1.5 bg-orange-500 rounded-full animate-pulse"></div>
                Checking payment status...
            </div>
        </div>

        <div id="state-success" class="hidden">
            <div class="w-20 h-20 mx-auto mb-6 bg-emerald-500/10 border border-emerald-500/20 rounded-full flex items-center justify-center">
                <svg class="w-10 h-10 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <h2 class="text-2xl font-black text-white tracking-tight mb-2">Payment Confirmed!</h2>
            <p class="text-gray-500 text-sm">Redirecting you to your dashboard...</p>
        </div>

        <div id="state-error" class="hidden">
            <div class="w-20 h-20 mx-auto mb-6 bg-red-500/10 border border-red-500/20 rounded-full flex items-center justify-center">
                <svg class="w-10 h-10 text-red-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/>
                </svg>
            </div>
            <h2 class="text-2xl font-black text-white tracking-tight mb-2">Payment Pending</h2>
            <p class="text-gray-500 text-sm mb-6">We couldn't confirm your payment yet. If you already paid, click below.</p>
            <a href="/subscription/success?plan=@plan&cycle=@Uri.EscapeDataString(cycle)&email=@Uri.EscapeDataString(email)"
               class="inline-flex px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all">
                I Already Paid — Activate Now
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        var linkId = '@linkId';
        var plan = '@plan';
        var email = '@email';
        var attempts = 0;
        var maxAttempts = 24; // 2 minutes total

        function checkPayment() {
            if (!linkId) {
                // No linkId — go directly to success
                activateSubscription();
                return;
            }

            fetch('/subscription/check-payment?linkId=' + encodeURIComponent(linkId))
                .then(r => r.json())
                .then(data => {
                    if (data.paid) {
                        showSuccess();
                        activateSubscription();
                    } else {
                        attempts++;
                        if (attempts >= maxAttempts) {
                            showError();
                        } else {
                            setTimeout(checkPayment, 5000);
                        }
                    }
                })
                .catch(() => {
                    attempts++;
                    if (attempts >= maxAttempts) showError();
                    else setTimeout(checkPayment, 5000);
                });
        }

        function activateSubscription() {
            window.location.href = '/subscription/success?plan=' + encodeURIComponent(plan) + '&cycle=' + encodeURIComponent('@cycle') + '&email=' + encodeURIComponent(email);
        }

        function showSuccess() {
            document.getElementById('state-checking').classList.add('hidden');
            document.getElementById('state-success').classList.remove('hidden');
        }

        function showError() {
            document.getElementById('state-checking').classList.add('hidden');
            document.getElementById('state-error').classList.remove('hidden');
        }

        // Start polling after 3 seconds
        setTimeout(checkPayment, 3000);
    </script>
}
