@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Choose a Plan";
    var billingEmail = ViewBag.BillingEmail as string ?? "";
    var planFree = ViewBag.PlanFree as PmesCSharp.Models.SubscriptionPlanDefinition;
    var planPro = ViewBag.PlanPro as PmesCSharp.Models.SubscriptionPlanDefinition;
    var trialDays = (int?)ViewBag.TrialDays ?? 15;
}

@if (TempData["Error"] is string error)
{
    <div class="mb-6 bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-4 py-3 rounded-xl">@error</div>
}

<div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 bg-orange-500/10 border border-orange-500/20 text-orange-400 text-xs font-semibold px-4 py-2 rounded-full mb-4">
            @trialDays-Day Free Trial Available
        </div>
        <h2 class="text-4xl font-black text-white tracking-tight">Choose your plan</h2>
        <p class="text-gray-500 mt-3 max-w-xl mx-auto">Start with a @trialDays-day free trial on Pro. No credit card required for trial.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
        <div id="card-free" onclick="selectPlan('Free')"
             class="relative bg-[#111114] border-2 border-orange-500 rounded-[24px] p-8 cursor-pointer transition-all duration-300 hover:bg-[#16161a]">
            <div class="absolute top-5 right-5 w-6 h-6 bg-orange-500 rounded-full flex items-center justify-center" id="check-free">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <div class="w-12 h-12 bg-blue-500/10 border border-blue-500/20 rounded-2xl flex items-center justify-center text-blue-400 mb-5">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <div class="text-lg font-bold text-white mb-1">Free</div>
            <div class="text-xs text-gray-500 mb-4">Get started</div>
            <div class="text-4xl font-black text-white mb-1">₱0<span class="text-base font-normal text-gray-500">/mo</span></div>
            <div class="text-xs text-gray-600 mb-6">No card required</div>
            <ul class="space-y-2.5 text-sm text-gray-400">
                @foreach (var f in new[] { "Production schedules & work orders", "Material requirements (MRP)", "Inventory movements", "QC inspections", "Invites allowed" })
                {
                    <li class="flex items-center gap-2.5">
                        <svg class="w-4 h-4 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        @f
                    </li>
                }
            </ul>
        </div>

        <div id="card-pro" onclick="selectPlan('Pro')"
             class="relative bg-[#111114] border-2 border-white/[0.08] rounded-[24px] p-8 cursor-pointer transition-all duration-300 hover:bg-[#16161a] hover:border-white/20">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="text-[10px] font-bold bg-orange-500 text-white px-3 py-1 rounded-full uppercase tracking-wider">Most Popular</span>
            </div>
            <div class="absolute top-5 right-5 w-6 h-6 bg-orange-500 rounded-full items-center justify-center hidden" id="check-pro">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <div class="w-12 h-12 bg-orange-500/10 border border-orange-500/20 rounded-2xl flex items-center justify-center text-orange-400 mb-5">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div class="text-lg font-bold text-white mb-1">Pro</div>
            <div class="text-xs text-gray-500 mb-4">Advanced controls</div>
            <div class="text-4xl font-black text-white mb-1">₱@((planPro?.MonthlyPriceCentavos ?? 4900_00) / 100)<span class="text-base font-normal text-gray-500">/mo</span></div>
            <div class="text-xs text-gray-600 mb-6">or ₱@((planPro?.AnnualPriceCentavos ?? 49000_00) / 100)/yr</div>
            <ul class="space-y-2.5 text-sm text-gray-400">
                @foreach (var f in new[] { "Everything in Free", "Production costing & reports", "Advanced audit & approvals", "Priority support & onboarding" })
                {
                    <li class="flex items-center gap-2.5">
                        <svg class="w-4 h-4 text-orange-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        @f
                    </li>
                }
            </ul>
        </div>
    </div>

    <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-6 bg-orange-500 rounded-full"></div>
            <h3 class="text-sm font-bold text-gray-500 uppercase tracking-[0.2em]">Billing Details</h3>
        </div>

        <form method="post" action="/subscription/checkout" id="checkout-form" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" name="plan" id="plan-input" value="Free" />
            <input type="hidden" name="cycle" id="cycle-input" value="Monthly" />

            <div>
                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Billing Cycle</label>
                <div class="grid grid-cols-2 gap-3">
                    <button type="button" onclick="selectCycle('Monthly')" id="cycle-monthly"
                            class="px-4 py-3 rounded-xl border border-orange-500 bg-orange-500/5 text-white text-sm font-bold transition-all">
                        Monthly
                    </button>
                    <button type="button" onclick="selectCycle('Annual')" id="cycle-annual"
                            class="px-4 py-3 rounded-xl border border-white/[0.08] bg-white/[0.02] text-gray-300 text-sm font-bold transition-all hover:border-white/20">
                        Annual
                    </button>
                </div>
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Billing Email</label>
                <input name="billingEmail" type="email" value="@billingEmail"
                       class="w-full bg-black/20 border border-white/[0.08] text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500/50 placeholder-gray-600 transition-all"
                       placeholder="billing@company.com">
            </div>

            <div class="flex items-center justify-between pt-2 flex-wrap gap-4">
                <div class="text-xs text-gray-600 flex items-center gap-2">
                    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    Secured by PayMongo · Test mode
                </div>
                <div class="flex items-center gap-3">
                    <button type="button" onclick="document.getElementById('trial-form').submit()"
                            class="px-5 py-2.5 bg-white/[0.03] hover:bg-white/[0.08] text-gray-400 text-sm font-bold rounded-xl border border-white/[0.05] transition-all">
                        Start Free Trial
                    </button>
                    <button type="submit" id="pay-btn"
                            class="px-6 py-2.5 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-orange-900/20">
                        Continue →
                    </button>
                </div>
            </div>
        </form>

        <form method="post" action="/subscription/trial" id="trial-form" class="hidden">
            @Html.AntiForgeryToken()
        </form>
    </div>

    <div class="mt-6 bg-blue-500/5 border border-blue-500/20 rounded-2xl p-5">
        <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div>
                <div class="text-sm font-bold text-blue-400 mb-1">Test Mode — Use these test card details</div>
                <div class="text-xs text-gray-400 space-y-1">
                    <div>Card Number: <span class="font-mono text-white">4343 4343 4343 4345</span></div>
                    <div>Expiry: <span class="font-mono text-white">any future date</span> &nbsp; CVC: <span class="font-mono text-white">any 3 digits</span></div>
                    <div>Name: <span class="font-mono text-white">any name</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var selectedPlan = 'Free';
    var selectedCycle = 'Monthly';

    function selectPlan(plan) {
        selectedPlan = plan;
        document.getElementById('plan-input').value = plan;

        var isFree = plan === 'Free';

        document.getElementById('card-free').classList.toggle('border-orange-500', isFree);
        document.getElementById('card-free').classList.toggle('border-white/[0.08]', !isFree);
        document.getElementById('check-free').classList.toggle('hidden', !isFree);

        document.getElementById('card-pro').classList.toggle('border-orange-500', !isFree);
        document.getElementById('card-pro').classList.toggle('border-white/[0.08]', isFree);
        var checkPro = document.getElementById('check-pro');
        checkPro.classList.toggle('hidden', isFree);
        checkPro.classList.toggle('flex', !isFree);

        refreshPayButton();
    }

    function selectCycle(cycle) {
        selectedCycle = cycle;
        document.getElementById('cycle-input').value = cycle;

        var isMonthly = cycle === 'Monthly';
        document.getElementById('cycle-monthly').classList.toggle('border-orange-500', isMonthly);
        document.getElementById('cycle-monthly').classList.toggle('bg-orange-500/5', isMonthly);
        document.getElementById('cycle-monthly').classList.toggle('border-white/[0.08]', !isMonthly);
        document.getElementById('cycle-monthly').classList.toggle('bg-white/[0.02]', !isMonthly);
        document.getElementById('cycle-monthly').classList.toggle('text-gray-300', !isMonthly);

        document.getElementById('cycle-annual').classList.toggle('border-orange-500', !isMonthly);
        document.getElementById('cycle-annual').classList.toggle('bg-orange-500/5', !isMonthly);
        document.getElementById('cycle-annual').classList.toggle('border-white/[0.08]', isMonthly);
        document.getElementById('cycle-annual').classList.toggle('bg-white/[0.02]', isMonthly);
        document.getElementById('cycle-annual').classList.toggle('text-gray-300', isMonthly);

        refreshPayButton();
    }

    function refreshPayButton() {
        var btn = document.getElementById('pay-btn');
        if (selectedPlan === 'Free') {
            btn.textContent = 'Activate Free →';
            return;
        }

        btn.textContent = (selectedCycle === 'Annual')
            ? 'Pay Annual with PayMongo →'
            : 'Pay Monthly with PayMongo →';
    }
</script>
