@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Planner Dashboard";
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
        <h2 class="text-2xl font-bold text-white tracking-tight">Production Planning</h2>
        <p class="text-sm text-gray-500 mt-1">Create schedules, generate work orders, and monitor progress.</p>
        <div class="mt-6 space-y-3">
            <a href="/progress" class="block px-6 py-3 bg-white/[0.03] hover:bg-white/[0.08] text-white text-sm font-bold rounded-xl border border-white/[0.05] transition-all">Progress Dashboard</a>
            <a href="/production/schedules" class="block px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-orange-900/20">Production Schedules</a>
            <a href="/production/work-orders" class="block px-6 py-3 bg-white/[0.03] hover:bg-white/[0.08] text-white text-sm font-bold rounded-xl border border-white/[0.05] transition-all">Work Orders</a>
        </div>
    </div>

    <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
        <h2 class="text-2xl font-bold text-white tracking-tight">Costing</h2>
        <p class="text-sm text-gray-500 mt-1">Compute material costs from BOM and add labor.</p>
        <div class="mt-6">
            <a href="/production/schedules" class="inline-flex px-6 py-3 bg-white/[0.03] hover:bg-white/[0.08] text-white text-sm font-bold rounded-xl border border-white/[0.05] transition-all">Open Schedules (for costing)</a>
        </div>
    </div>
</div>
