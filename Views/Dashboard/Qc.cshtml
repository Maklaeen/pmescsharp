@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "QC Dashboard";
}

<div class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="/production/schedules"
           class="group bg-[#111114] border border-white/[0.05] rounded-[24px] p-7 hover:border-orange-500/20 hover:bg-[#16161a] transition-all duration-300 block">
            <div class="w-12 h-12 bg-emerald-500/10 border border-emerald-500/20 rounded-2xl flex items-center justify-center text-emerald-400 mb-5 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <h3 class="font-bold text-white text-lg mb-1">Quality Inspections</h3>
            <p class="text-gray-500 text-sm leading-relaxed">Record pass/fail results, qty passed/failed, and defect notes per production schedule.</p>
            <div class="mt-5 flex items-center gap-2 text-xs font-bold text-orange-500 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                Open Schedules <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
        </a>

        <a href="/qc/inspections"
           class="group bg-[#111114] border border-white/[0.05] rounded-[24px] p-7 hover:border-orange-500/20 hover:bg-[#16161a] transition-all duration-300 block">
            <div class="w-12 h-12 bg-purple-500/10 border border-purple-500/20 rounded-2xl flex items-center justify-center text-purple-400 mb-5 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
            </div>
            <h3 class="font-bold text-white text-lg mb-1">Inspection History</h3>
            <p class="text-gray-500 text-sm leading-relaxed">View all past QC inspection results across all production schedules.</p>
            <div class="mt-5 flex items-center gap-2 text-xs font-bold text-orange-500 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                View History <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
        </a>
    </div>

    <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-6 bg-orange-500 rounded-full"></div>
            <h2 class="text-sm font-bold text-gray-500 uppercase tracking-[0.2em]">QC Rules</h2>
        </div>
        <ul class="space-y-3 text-sm text-gray-400">
            <li class="flex items-start gap-2"><span class="text-orange-400 mt-0.5">→</span> QC is only available after <strong class="text-gray-300">all work orders</strong> in a schedule are marked <strong class="text-emerald-400">DONE</strong>.</li>
            <li class="flex items-start gap-2"><span class="text-orange-400 mt-0.5">→</span> A schedule can only be <strong class="text-gray-300">completed</strong> after a <strong class="text-emerald-400">PASSED</strong> QC result.</li>
            <li class="flex items-start gap-2"><span class="text-orange-400 mt-0.5">→</span> Multiple QC entries are allowed per schedule — latest result is shown on the dashboard.</li>
        </ul>
    </div>
</div>
