@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
    <h2 class="text-2xl font-bold text-white tracking-tight">No role assigned</h2>
    <p class="text-sm text-gray-500 mt-2">Your account is logged in, but no role is assigned yet.</p>

    <div class="mt-6 p-5 rounded-2xl bg-white/[0.03] border border-white/[0.05]">
        <div class="text-xs font-bold text-gray-600 uppercase tracking-[0.2em]">Required roles</div>
        <p class="text-sm text-gray-400 mt-2">Assign one of these roles to your user: <span class="text-gray-300 font-semibold">superadmin</span>, <span class="text-gray-300 font-semibold">admin</span>, <span class="text-gray-300 font-semibold">planner</span>, <span class="text-gray-300 font-semibold">inventory</span>, <span class="text-gray-300 font-semibold">operator</span>, <span class="text-gray-300 font-semibold">qc</span>.</p>
    </div>
</div>
