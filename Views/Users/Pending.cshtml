@model List<PmesCSharp.ViewModels.Users.PendingApprovalUserViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Pending Approvals";
}

@if (TempData["Success"] is string success)
{
    <div class="mb-6 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm px-4 py-3 rounded-xl">@success</div>
}

<div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
    <div class="flex items-center justify-between mb-10">
        <div>
            <h2 class="text-2xl font-bold text-white tracking-tight">Pending approvals</h2>
            <p class="text-sm text-gray-500 mt-1">Invited users must be approved before they can log in.</p>
        </div>
        <a href="/users/invites" class="px-5 py-3 bg-white/[0.03] hover:bg-white/[0.08] text-gray-400 text-sm font-bold rounded-xl border border-white/[0.05] transition-all">← Back to Invites</a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-separate border-spacing-y-3">
            <thead>
                <tr class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">
                    <th class="px-6 py-4">User</th>
                    <th class="px-6 py-4">Requested</th>
                    <th class="px-6 py-4">Pending Role</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="4" class="px-6 py-10 text-sm text-gray-500">No pending users.</td></tr>
                }
                @foreach (var u in Model)
                {
                    var initials = new string((u.Name ?? u.Email ?? "?").Take(2).ToArray()).ToUpperInvariant();
                    <tr class="bg-white/[0.02] hover:bg-white/[0.05] transition-colors group">
                        <td class="px-6 py-5 rounded-l-2xl border-y border-l border-white/[0.05]">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center font-bold text-white shadow-lg">@initials</div>
                                <div>
                                    <div class="text-sm font-bold text-white">@(string.IsNullOrWhiteSpace(u.Name) ? u.Email : u.Name)</div>
                                    <div class="text-xs text-gray-500">@u.Email</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05] text-xs text-gray-400">@(u.RequestedAt?.ToLocalTime().ToString("MMM dd, yyyy HH:mm") ?? "-")</td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <span class="text-[10px] font-bold text-orange-500 uppercase tracking-widest bg-orange-500/5 px-2.5 py-1 rounded-lg border border-orange-500/10">@(string.IsNullOrWhiteSpace(u.PendingRole) ? "operator" : u.PendingRole)</span>
                        </td>
                        <td class="px-6 py-5 rounded-r-2xl border-y border-r border-white/[0.05] text-right">
                            <form method="post" action="/users/@u.Id/approve" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="px-4 py-2 text-xs font-bold rounded-xl bg-emerald-600/20 hover:bg-emerald-600/30 border border-emerald-500/30 text-emerald-300 transition-all">Approve</button>
                            </form>
                            <form method="post" action="/users/@u.Id/reject" class="inline ml-2" onsubmit="return confirm('Reject this user?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="px-4 py-2 text-xs font-bold rounded-xl bg-red-600/20 hover:bg-red-600/30 border border-red-500/30 text-red-300 transition-all">Reject</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
