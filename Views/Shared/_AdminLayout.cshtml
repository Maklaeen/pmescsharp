@using Microsoft.AspNetCore.Identity
@using PmesCSharp.Models
@inject UserManager<ApplicationUser> UserManager
@{
    var currentUser = await UserManager.GetUserAsync(User);
    var roles = currentUser is null ? new List<string>() : (await UserManager.GetRolesAsync(currentUser)).ToList();
    var roleName = roles.FirstOrDefault() ?? "superadmin";

    var dashboardPath = roleName switch
    {
        "planner" => "/planner/dashboard",
        "inventory" => "/inventory/dashboard",
        "operator" => "/operator/dashboard",
        "qc" => "/qc/dashboard",
        _ => "/admin/dashboard",
    };

    var isMasterDataRole = roleName is "superadmin" or "admin";
    var canSeeAuditLogs = roleName is "superadmin" or "admin";
    var canSeeSchedules = roleName is "superadmin" or "admin" or "planner" or "inventory" or "qc";
    var canSeeWorkOrders = roleName is "superadmin" or "admin" or "planner" or "operator";
    var canSeeCosting = roleName is "superadmin" or "admin" or "planner";
    var canSeeInventory = roleName is "superadmin" or "admin" or "inventory";
    var canSeeQc = roleName is "superadmin" or "admin" or "qc";
    var canSeeProductionProgress = roleName is "superadmin" or "admin" or "planner";

    var path = Context.Request.Path.Value ?? "";
    bool IsActiveExact(string p) => string.Equals(path, p, StringComparison.OrdinalIgnoreCase);
    bool IsActivePrefix(string p) => path.StartsWith(p, StringComparison.OrdinalIgnoreCase);

    var displayName = string.IsNullOrWhiteSpace(currentUser?.FullName) ? (currentUser?.Email ?? "") : currentUser!.FullName;
    var initials = new string(displayName.Take(2).ToArray()).ToUpperInvariant();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewData["Title"] ?? "Dashboard") – PMES</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <style type="text/tailwindcss">
        @@layer base {
            body {
                font-family: 'Plus Jakarta Sans', sans-serif;
                @@apply bg-[#0c0c0e] text-gray-200;
            }

            body.theme-light {
                @@apply bg-gray-100 text-gray-900;
            }
        }
        @@layer components {
            .sidebar-link {
                @@apply flex items-center gap-3 px-4 py-3 rounded-xl text-[13px] font-semibold text-gray-500 hover:text-white hover:bg-white/5 transition-all duration-200;
            }
            .sidebar-link.active {
                @@apply text-orange-500 bg-orange-500/10 relative;
            }
            .sidebar-link.active::before {
                content: '';
                @@apply absolute left-0 top-1/2 -translate-y-1/2 w-1 h-5 bg-orange-500 rounded-r-full;
            }
            .custom-scrollbar::-webkit-scrollbar {
                width: 4px;
            }
            .custom-scrollbar::-webkit-scrollbar-track {
                background: transparent;
            }
            .custom-scrollbar::-webkit-scrollbar-thumb {
                @@apply bg-gray-800 rounded-full;
            }

            body.theme-light .sidebar-link {
                @@apply text-gray-600 hover:text-gray-900;
            }
            body.theme-light .sidebar-link.active {
                @@apply text-orange-600 bg-orange-500/10;
            }
            body.theme-light aside {
                @@apply bg-white border-gray-200;
            }
            body.theme-light header {
                @@apply border-gray-200;
            }
            body.theme-light main {
                @@apply bg-gray-100;
            }
        }
    </style>

    <script>
        (function () {
            try {
                var theme = localStorage.getItem('theme') || 'dark';
                if (theme === 'light') document.body.classList.add('theme-light');
            } catch (e) { }
        })();
    </script>
</head>
<body class="text-gray-200">
<div class="flex h-screen overflow-hidden">

    <aside class="w-72 bg-[#0c0c0e] border-r border-white/[0.05] flex flex-col flex-shrink-0">
        <div class="px-8 py-10 flex items-center gap-4">
            <img src="/images/LOGO.png" alt="PMES Logo" class="w-11 h-11 object-contain">
            <div>
                <div class="font-extrabold text-lg text-white tracking-tight leading-tight">PMES</div>
                <div class="text-[10px] font-bold text-gray-600 uppercase tracking-[0.2em] mt-1">MES v1.0</div>
            </div>
        </div>

        <nav class="flex-1 px-4 space-y-1 overflow-y-auto custom-scrollbar pb-10">
            <div class="px-4 mb-4 mt-2">
                <p class="text-[11px] font-bold text-gray-700 uppercase tracking-[0.25em]">Main</p>
            </div>
            <a href="@dashboardPath" class="sidebar-link @(IsActiveExact(dashboardPath) ? "active" : "")">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                Dashboard
            </a>

            @if (isMasterDataRole)
            {
                <div class="px-4 mb-4 mt-10">
                    <p class="text-[11px] font-bold text-gray-700 uppercase tracking-[0.25em]">Master Data</p>
                </div>
                <a href="/admin/users" class="sidebar-link @(IsActivePrefix("/admin/users") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Users
                </a>
                <a href="/admin/users/invites" class="sidebar-link @(IsActivePrefix("/admin/users/invites") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 12h6m-6 4h6M4 8h8M4 12h8m-8 4h8"/></svg>
                    User Invites
                </a>
                <a href="/admin/products" class="sidebar-link @(IsActivePrefix("/admin/products") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    Products
                </a>
                <a href="/admin/materials" class="sidebar-link @(IsActivePrefix("/admin/materials") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                    Materials
                </a>
                <a href="/admin/bom" class="sidebar-link @(IsActivePrefix("/admin/bom") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    Bill of Materials
                </a>
            }

            <div class="px-4 mb-4 mt-10">
                <p class="text-[11px] font-bold text-gray-700 uppercase tracking-[0.25em]">Production</p>
            </div>
            @if (canSeeProductionProgress)
            {
                <a href="/production/dashboard" class="sidebar-link @(IsActivePrefix("/production/dashboard") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 14l3-3 3 3 6-6"/></svg>
                    Progress Dashboard
                </a>
            }
            @if (canSeeSchedules)
            {
                <a href="/production/schedules" class="sidebar-link @(IsActivePrefix("/production/schedules") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7"/></svg>
                    Production Schedules
                </a>
            }
            @if (canSeeWorkOrders)
            {
                <a href="/production/work-orders" class="sidebar-link @(IsActivePrefix("/production/work-orders") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Work Orders
                </a>
            }
            @if (canSeeInventory)
            {
                <a href="/inventory/material-movements" class="sidebar-link @(IsActivePrefix("/inventory/material-movements") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7h18M3 12h18M3 17h18"/></svg>
                    Material Movements
                </a>
            }
            @if (canSeeCosting)
            {
                <a href="/costing" class="sidebar-link @(IsActivePrefix("/costing") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg>
                    Production Costing
                </a>
            }
            @if (canSeeQc)
            {
                <a href="/qc/inspections" class="sidebar-link @(IsActivePrefix("/qc/inspections") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Quality Control
                </a>
            }

            @if (canSeeAuditLogs)
            {
                <a href="/admin/audit-logs" class="sidebar-link @(IsActivePrefix("/admin/audit-logs") ? "active" : "")">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    Audit Logs
                </a>
            }

            <div class="px-4 mb-4 mt-10">
                <p class="text-[11px] font-bold text-gray-700 uppercase tracking-[0.25em]">System</p>
            </div>
            <a href="/profile" class="sidebar-link @(IsActivePrefix("/profile") ? "active" : "")">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                My Profile
            </a>
            <a href="/company/profile" class="sidebar-link @(IsActivePrefix("/company/profile") ? "active" : "")">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-8h6v8"/></svg>
                Company Profile
            </a>
            <a href="/settings" class="sidebar-link @(IsActivePrefix("/settings") ? "active" : "")">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 16v-2m6-6h2M4 12H6m12.364-5.364l1.414-1.414M4.222 19.778l1.414-1.414m0-12.728L4.222 4.222m15.556 15.556l-1.414-1.414M12 8a4 4 0 100 8 4 4 0 000-8z"/></svg>
                Settings
            </a>
          <a href="/subscription" class="sidebar-link @(IsActivePrefix("/subscription") ? "active" : "")">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 1.343-3 3v1H8a2 2 0 00-2 2v4h12v-4a2 2 0 00-2-2h-1v-1c0-1.657-1.343-3-3-3z"/></svg>
                Subscription
            </a>
        </nav>

        <div class="p-6 border-t border-white/[0.05] bg-[#0c0c0e]">
            <div class="flex items-center gap-4 p-3 rounded-2xl bg-white/[0.03] border border-white/[0.05] group">
                <div class="w-11 h-11 bg-blue-600 rounded-xl flex items-center justify-center font-bold text-white shadow-lg shadow-blue-900/20">
                    @initials
                </div>
                <div class="flex-1 min-w-0">
                    <div class="text-[13px] font-bold text-white truncate">@displayName</div>
                    <div class="text-[10px] font-bold text-gray-600 truncate uppercase tracking-wider mt-0.5">@char.ToUpperInvariant(roleName[0])@roleName.Substring(1)</div>
                </div>
                <form method="post" action="/logout" class="opacity-0 group-hover:opacity-100 transition-opacity">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="p-2 text-gray-500 hover:text-red-400 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <div class="flex-1 flex flex-col min-w-0 bg-[#0c0c0e]">
        <header class="h-20 border-b border-gray-800/50 px-8 flex items-center justify-between flex-shrink-0">
            <h1 class="text-2xl font-bold text-white tracking-tight">@(ViewData["Title"] ?? "Dashboard")</h1>
            <div class="flex items-center gap-4">
                <form method="post" action="/settings/theme" class="hidden md:block" id="themeToggleForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="theme" id="themeToggleValue" value="dark" />
                    <button type="submit" class="px-3 py-1.5 rounded-full border border-gray-800 bg-gray-900 text-[11px] font-bold text-gray-400 hover:text-white">
                        Toggle Theme
                    </button>
                </form>
                <div class="hidden md:flex items-center gap-2 px-3 py-1.5 bg-orange-500/10 border border-orange-500/20 rounded-full">
                    <div class="w-1.5 h-1.5 bg-orange-500 rounded-full animate-pulse"></div>
                    <span class="text-[11px] font-bold text-orange-500 uppercase tracking-wider">@roleName</span>
                </div>
                <div class="text-[11px] font-medium text-gray-500 bg-gray-900 px-3 py-1.5 rounded-full border border-gray-800">@DateTime.Now.ToString("MMM dd, yyyy")</div>
            </div>
        </header>

        <main class="flex-1 p-8 overflow-y-auto custom-scrollbar">
            <div class="max-w-[1400px] mx-auto">
                @RenderBody()
            </div>
        </main>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    (function () {
        if (!window.flatpickr) return;

        document.querySelectorAll('input.js-datepicker').forEach(function (el) {
            window.flatpickr(el, {
                dateFormat: 'Y-m-d',
                allowInput: false,
            });
        });

        document.querySelectorAll('input.js-datetimepicker').forEach(function (el) {
            window.flatpickr(el, {
                enableTime: true,
                time_24hr: true,
                dateFormat: 'Y-m-d H:i',
                allowInput: false,
            });
        });
    })();
</script>

<script>
    (function () {
        var form = document.getElementById('themeToggleForm');
        var value = document.getElementById('themeToggleValue');
        if (!form || !value) return;

        form.addEventListener('submit', function () {
            try {
                var current = localStorage.getItem('theme') || 'dark';
                var next = current === 'dark' ? 'light' : 'dark';
                value.value = next;
                localStorage.setItem('theme', next);
            } catch (e) { }
        });
    })();
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
