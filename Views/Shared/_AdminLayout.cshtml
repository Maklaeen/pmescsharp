<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    (function () {
        if (!window.flatpickr) return;

        document.querySelectorAll('input.js-datepicker').forEach(function (el) {
            window.flatpickr(el, {
                dateFormat: 'Y-m-d',
                allowInput: false,
            });
        });

        document.querySelectorAll('input.js-datetimepicker').forEach(function (el) {
            window.flatpickr(el, {
                enableTime: true,
                time_24hr: true,
                dateFormat: 'Y-m-d H:i',
                allowInput: false,
            });
        });
    })();
</script>

@await RenderSectionAsync("Scripts", required: false)

<script>
    // Dashboard theme toggle
    (function () {
        const THEME_KEY = 'pmes-theme';
        const CYCLE = ['system','light','dark'];

        function applyDashTheme(t) {
            const dark = t === 'dark' || (t === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
            document.documentElement.classList.toggle('theme-light', !dark);
            const tl = document.getElementById('dt-light');
            const td = document.getElementById('dt-dark');
            const ts = document.getElementById('dt-system');
            if (tl) tl.classList.toggle('hidden', t !== 'light');
            if (td) td.classList.toggle('hidden', t !== 'dark');
            if (ts) ts.classList.toggle('hidden', t !== 'system');
            document.querySelectorAll('.dash-theme-opt').forEach(btn => {
                btn.classList.toggle('text-orange-400', btn.dataset.t === t);
                btn.classList.toggle('text-gray-300', btn.dataset.t !== t);
            });
        }

        window.setDashTheme = function(t) {
            localStorage.setItem(THEME_KEY, t);
            localStorage.setItem('theme', t === 'system' ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light') : t);
            applyDashTheme(t);
            document.getElementById('dash-theme-menu').classList.add('hidden');
            // Persist to server
            fetch('/settings/theme', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name=__RequestVerificationToken]')?.value ?? '' }, body: JSON.stringify({ theme: t === 'system' ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light') : t }) }).catch(() => {});
        };

        window.toggleDashThemeMenu = function() {
            document.getElementById('dash-theme-menu').classList.toggle('hidden');
        };

        document.addEventListener('click', function(e) {
            const wrapper = document.getElementById('dash-theme-wrapper');
            if (wrapper && !wrapper.contains(e.target)) {
                document.getElementById('dash-theme-menu').classList.add('hidden');
            }
        });

        const saved = localStorage.getItem(THEME_KEY) || 'dark';
        applyDashTheme(saved);

        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
            if ((localStorage.getItem(THEME_KEY) || 'dark') === 'system') applyDashTheme('system');
        });
    })();
</script>

<!-- Page loader -->
<div id="page-loader">
    <div id="page-loader-bar"></div>
    <div id="page-loader-skeleton">
        <div class="sk-header skeleton"></div>
        <div class="sk-subheader skeleton"></div>
        <div class="sk-cards">
            <div class="sk-card skeleton"></div>
            <div class="sk-card skeleton"></div>
            <div class="sk-card skeleton"></div>
            <div class="sk-card skeleton"></div>
        </div>
        <div class="sk-table-header skeleton"></div>
        <div class="sk-row skeleton"></div>
        <div class="sk-row skeleton"></div>
        <div class="sk-row skeleton"></div>
        <div class="sk-row-sm skeleton"></div>
        <div class="sk-row-sm skeleton"></div>
    </div>
</div>

<script>
    (function () {
        var loader = document.getElementById('page-loader');
        var bar = document.getElementById('page-loader-bar');
        var timer, barTimer;

        function showLoader() {
            loader.classList.add('active');
            bar.style.width = '0%';
            // Animate bar to 80% quickly, then slow down
            clearTimeout(barTimer);
            setTimeout(function () { bar.style.width = '60%'; }, 50);
            barTimer = setTimeout(function () { bar.style.width = '80%'; }, 400);
        }

        function hideLoader() {
            bar.style.width = '100%';
            setTimeout(function () {
                loader.classList.remove('active');
                bar.style.width = '0%';
            }, 300);
        }

        // Show skeleton on navigation links (not forms, not external, not anchors)
        document.addEventListener('click', function (e) {
            var el = e.target.closest('a[href]');
            if (!el) return;
            var href = el.getAttribute('href');
            if (!href || href.startsWith('#') || href.startsWith('javascript') || href.startsWith('mailto')) return;
            if (el.target === '_blank') return;
            try {
                var url = new URL(href, window.location.origin);
                if (url.origin !== window.location.origin) return;
                // Don't show for same page
                if (url.pathname === window.location.pathname && url.search === window.location.search) return;
            } catch (err) { return; }
            showLoader();
        });

        // Show on form submit (POST navigations)
        document.addEventListener('submit', function (e) {
            var form = e.target;
            // Skip forms that use fetch/ajax
            if (form.dataset.noLoader) return;
            showLoader();
        });

        // Hide on page show (back/forward cache)
        window.addEventListener('pageshow', function (e) {
            hideLoader();
        });

        // Hide if page load completes (safety net)
        window.addEventListener('load', function () {
            hideLoader();
        });
    })();
</script>
<script>
    (function () {
        function loadNotifCount() {
            fetch('/notifications/unread-count')
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    var badge = document.getElementById('notif-count');
                    if (!badge) return;
                    if (d.count > 0) {
                        badge.textContent = d.count > 99 ? '99+' : d.count;
                        badge.classList.remove('hidden');
                    } else {
                        badge.classList.add('hidden');
                    }
                }).catch(function () {});
        }
        loadNotifCount();
        setInterval(loadNotifCount, 60000);
    })();
</script>
<script>
    function openSidebar() {
        document.getElementById('sidebar').classList.remove('-translate-x-full');
        document.getElementById('sidebar-overlay').classList.remove('hidden');
    }
    function closeSidebar() {
        document.getElementById('sidebar').classList.add('-translate-x-full');
        document.getElementById('sidebar-overlay').classList.add('hidden');
    }
    // Close sidebar on nav link click (mobile)
    document.querySelectorAll('#sidebar a').forEach(function(a) {
        a.addEventListener('click', function() {
            if (window.innerWidth < 1024) closeSidebar();
        });
    });
</script>
