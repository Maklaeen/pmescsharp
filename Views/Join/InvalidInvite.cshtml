@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invalid invite – PMES</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white text-gray-900 min-h-screen flex items-center justify-center px-4">
    <div class="max-w-md w-full text-center">
        <h1 class="text-2xl font-bold">Invite link is invalid</h1>
        <p class="text-gray-600 mt-2">This invite may have expired, been revoked, or already used.</p>
        <a href="/login" class="inline-block mt-6 px-5 py-2.5 rounded-lg bg-orange-500 text-white font-semibold">Go to Login</a>
    </div>
</body>
</html>
