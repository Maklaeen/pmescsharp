@model PmesCSharp.ViewModels.Company.CompanyProfileViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Company Profile";
}

<div class="bg-gray-900/40 border border-gray-800/50 rounded-2xl p-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <div class="text-xs font-bold text-gray-500 uppercase tracking-[0.2em]">System</div>
            <h2 class="text-xl font-extrabold text-white tracking-tight mt-1">Company Profile</h2>
        </div>
    </div>

    @if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="mb-6 text-emerald-400 text-sm bg-emerald-400/10 border border-emerald-400/20 rounded-lg px-4 py-2">@ok</div>
    }
    @if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="mb-6 text-red-400 text-sm bg-red-400/10 border border-red-400/20 rounded-lg px-4 py-2">@err</div>
    }

    @if (User.IsInRole("superadmin") || User.IsInRole("admin"))
    {
    <form method="post" action="/company" class="space-y-5">
        @Html.AntiForgeryToken()

        <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Display Name</label>
            <input name="DisplayName" value="@Model.DisplayName" required
                   class="w-full bg-gray-800/60 border border-gray-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" />
            <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.DisplayName)</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Email</label>
                <input name="Email" value="@Model.Email"
                       class="w-full bg-gray-800/60 border border-gray-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" />
                <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Email)</span>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Phone</label>
                <input name="Phone" value="@Model.Phone"
                       class="w-full bg-gray-800/60 border border-gray-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" />
                <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Phone)</span>
            </div>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Address</label>
            <input name="Address" value="@Model.Address"
                   class="w-full bg-gray-800/60 border border-gray-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" />
            <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Address)</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Website</label>
                <input name="Website" value="@Model.Website"
                       class="w-full bg-gray-800/60 border border-gray-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" />
                <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Website)</span>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Industry</label>
                <input name="Industry" value="@Model.Industry"
                       class="w-full bg-gray-800/60 border border-gray-700 text-white rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" />
                <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Industry)</span>
            </div>
        </div>

        <div class="pt-2">
            <button type="submit" class="bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2.5 px-6 rounded-lg transition text-sm">
                Save Changes
            </button>
        </div>
    </form>
    }
    else
    {
        <div class="space-y-5">
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Display Name</span><div class="text-white mt-1">@Model.DisplayName</div></div>
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Email</span><div class="text-white mt-1">@(Model.Email ?? "—")</div></div>
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Phone</span><div class="text-white mt-1">@(Model.Phone ?? "—")</div></div>
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Address</span><div class="text-white mt-1">@(Model.Address ?? "—")</div></div>
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Website</span><div class="text-white mt-1">@(Model.Website ?? "—")</div></div>
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Industry</span><div class="text-white mt-1">@(Model.Industry ?? "—")</div></div>
        </div>
    }
</div>
