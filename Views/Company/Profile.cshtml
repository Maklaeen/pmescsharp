@model PmesCSharp.ViewModels.Company.CompanyProfileViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Company Profile";
}

<div class="bg-gray-900/40 border border-gray-800/50 rounded-2xl p-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <div class="text-xs font-bold text-gray-500 uppercase tracking-[0.2em]">System</div>
            <h2 class="text-xl font-extrabold text-white tracking-tight mt-1">Company Profile</h2>
        </div>
    </div>

    @if (ViewBag.NextAllowed != null)
    {
        <div id="profile-blocked" class="mb-6 text-yellow-300 text-sm bg-yellow-500/10 border border-yellow-500/20 rounded-lg px-4 py-3" role="alert" aria-live="assertive">
            Profile updates are blocked until <strong>@ViewBag.NextAllowed</strong>. Last updated: <strong>@ViewBag.ProfileUpdatedAt</strong>.
        </div>
    }

    @if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="mb-6 text-emerald-400 text-sm bg-emerald-400/10 border border-emerald-400/20 rounded-lg px-4 py-2">@ok</div>
    }
    @if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div id="profile-error" class="mb-6 text-red-400 text-sm bg-red-400/10 border border-red-400/20 rounded-lg px-4 py-2" role="alert" aria-live="assertive">@err</div>
    }

    @if (User.IsInRole("superadmin") || User.IsInRole("admin"))
    {
    <form method="post" action="/company" data-confirm="Save changes to company profile?" class="space-y-5">
        @Html.AntiForgeryToken()

        <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Display Name</label>
            <input name="DisplayName" value="@Model.DisplayName" required
                   class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500 transition" />
            <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.DisplayName)</span>
        </div>

    <script>
        // If the server returned a NextAllowed date, focus the banner and gently highlight it
        (function(){
            const blocked = document.getElementById('profile-blocked');
            if(blocked){
                blocked.scrollIntoView({behavior:'smooth', block:'center'});
                blocked.classList.add('ring-2','ring-yellow-400');
                setTimeout(()=> blocked.classList.remove('ring-2','ring-yellow-400'), 3000);
            }
            const err = document.getElementById('profile-error');
            if(err){
                err.scrollIntoView({behavior:'smooth', block:'center'});
            }
        })();
    </script>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Email</label>
                <input name="Email" value="@Model.Email"
                       class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500 transition" />
                <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Email)</span>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Phone</label>
                <input name="Phone" value="@Model.Phone"
                       class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500 transition" />
                <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Phone)</span>
            </div>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-300 mb-1.5">Address</label>
            <input name="Address" value="@Model.Address"
                   class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500 transition" />
            <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Address)</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Website</label>
                <input name="Website" value="@Model.Website"
                       class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500 transition" />
                <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Website)</span>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-1.5">Industry</label>
                <input name="Industry" value="@Model.Industry"
                       class="w-full bg-black/20 border border-white/[0.08] rounded-2xl px-4 py-3 text-sm text-white focus:outline-none focus:ring-2 focus:ring-orange-500 transition" />
                <span class="text-red-400 text-xs mt-1.5 block">@Html.ValidationMessageFor(m => m.Industry)</span>
            </div>
        </div>

        <div class="pt-4 border-t border-white/[0.05]">
            <button type="submit" class="px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-orange-900/20">
                Save Changes
            </button>
        </div>
    </form>

    @if (Model.Users.Any())
    {
        <div class="mt-8 bg-gray-800/40 border border-white/[0.08] rounded-2xl p-6">
            <div class="mb-6 flex items-center justify-between gap-4">
                <div>
                    <div class="text-xs font-bold text-gray-500 uppercase tracking-[0.2em]">Company Users</div>
                    <div class="text-sm text-white mt-1">All users assigned to this company.</div>
                </div>
                <span class="text-xs font-semibold text-gray-400 uppercase tracking-[0.15em]">@Model.Users.Count user(s)</span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-separate border-spacing-y-3">
                    <thead>
                        <tr class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">
                            <th class="px-4 py-3">Name</th>
                            <th class="px-4 py-3">Email</th>
                            <th class="px-4 py-3">Role</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr class="bg-white/[0.02] hover:bg-white/[0.05] transition-colors">
                                <td class="px-4 py-3 text-sm text-white">@user.Name</td>
                                <td class="px-4 py-3 text-sm text-gray-300">@user.Email</td>
                                <td class="px-4 py-3 text-sm text-orange-400 uppercase tracking-[0.1em]">@user.Role</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="mt-8 px-4 py-3 rounded-2xl bg-black/20 border border-white/[0.05] text-sm text-gray-400">
            No users have been assigned to this company yet.
        </div>
    }
    }
    else
    {
        <div class="space-y-5">
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Display Name</span><div class="text-white mt-1">@Model.DisplayName</div></div>
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Email</span><div class="text-white mt-1">@(Model.Email ?? "—")</div></div>
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Phone</span><div class="text-white mt-1">@(Model.Phone ?? "—")</div></div>
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Address</span><div class="text-white mt-1">@(Model.Address ?? "—")</div></div>
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Website</span><div class="text-white mt-1">@(Model.Website ?? "—")</div></div>
            <div><span class="text-xs text-gray-500 uppercase tracking-widest">Industry</span><div class="text-white mt-1">@(Model.Industry ?? "—")</div></div>
        </div>
    }
</div>
