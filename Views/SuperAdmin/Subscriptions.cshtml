@model IEnumerable<dynamic>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Company Subscriptions";
}

@if (TempData["Success"] is string ok)
{
    <div class="mb-6 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm px-4 py-3 rounded-xl">@ok</div>
}

<div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h2 class="text-2xl font-bold text-white tracking-tight">Company Subscriptions</h2>
            <p class="text-sm text-gray-500 mt-1">View and override subscription per company.</p>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-separate border-spacing-y-3">
            <thead>
            <tr class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">
                <th class="px-6 py-4">Company</th>
                <th class="px-6 py-4">Code</th>
                <th class="px-6 py-4">Plan</th>
                <th class="px-6 py-4">Status</th>
                <th class="px-6 py-4">Period Ends</th>
                <th class="px-6 py-4 text-right">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var row in Model)
            {
                var sub = row.Subscription as PmesCSharp.Models.CompanySubscription;
                <tr class="bg-white/[0.02] border border-white/[0.05]">
                    <td class="px-6 py-5 rounded-l-2xl border-y border-l border-white/[0.05] text-white font-bold">@row.Name</td>
                    <td class="px-6 py-5 border-y border-white/[0.05] text-gray-400">@row.Code</td>
                    <td class="px-6 py-5 border-y border-white/[0.05] text-gray-300">@(sub?.Plan.ToString() ?? "—")</td>
                    <td class="px-6 py-5 border-y border-white/[0.05] text-gray-300">@(sub?.Status.ToString() ?? "—")</td>
                    <td class="px-6 py-5 border-y border-white/[0.05] text-gray-400">@(sub?.CurrentPeriodEndsAt?.ToString("yyyy-MM-dd") ?? "—")</td>
                    <td class="px-6 py-5 rounded-r-2xl border-y border-r border-white/[0.05] text-right">
                        <a href="/superadmin/subscriptions/@row.Id" class="px-4 py-2 text-xs font-bold rounded-xl bg-orange-600 hover:bg-orange-700 text-white transition-all">Override</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
