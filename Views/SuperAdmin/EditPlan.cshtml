@model PmesCSharp.ViewModels.SuperAdmin.PlanEditViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Plan";
}

<div class="max-w-3xl space-y-6">
    <div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h2 class="text-2xl font-bold text-white tracking-tight">Edit @Model.Plan</h2>
                <p class="text-sm text-gray-500 mt-1">Pricing, feature flags, and limits.</p>
            </div>
            <a href="/superadmin/plans" class="text-sm text-gray-400 hover:text-white">Back</a>
        </div>

        <form method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Plan" />

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Currency</label>
                    <input asp-for="Currency" class="w-full bg-black/20 border border-white/[0.08] text-white rounded-xl px-4 py-3 text-sm" />
                    <span asp-validation-for="Currency" class="text-xs text-red-400"></span>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Monthly (centavos)</label>
                    <input asp-for="MonthlyPriceCentavos" type="number" class="w-full bg-black/20 border border-white/[0.08] text-white rounded-xl px-4 py-3 text-sm" />
                    <span asp-validation-for="MonthlyPriceCentavos" class="text-xs text-red-400"></span>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Annual (centavos)</label>
                    <input asp-for="AnnualPriceCentavos" type="number" class="w-full bg-black/20 border border-white/[0.08] text-white rounded-xl px-4 py-3 text-sm" />
                    <span asp-validation-for="AnnualPriceCentavos" class="text-xs text-red-400"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Max Users</label>
                    <input asp-for="MaxUsers" type="number" class="w-full bg-black/20 border border-white/[0.08] text-white rounded-xl px-4 py-3 text-sm" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Max Products</label>
                    <input asp-for="MaxProducts" type="number" class="w-full bg-black/20 border border-white/[0.08] text-white rounded-xl px-4 py-3 text-sm" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Max Materials</label>
                    <input asp-for="MaxMaterials" type="number" class="w-full bg-black/20 border border-white/[0.08] text-white rounded-xl px-4 py-3 text-sm" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Max Work Orders / Month</label>
                    <input asp-for="MaxWorkOrdersPerMonth" type="number" class="w-full bg-black/20 border border-white/[0.08] text-white rounded-xl px-4 py-3 text-sm" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Max Storage (MB)</label>
                    <input asp-for="MaxStorageMb" type="number" class="w-full bg-black/20 border border-white/[0.08] text-white rounded-xl px-4 py-3 text-sm" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <label class="flex items-center gap-3 p-4 rounded-xl bg-white/[0.02] border border-white/[0.05]">
                    <input asp-for="EnableReports" type="checkbox" class="h-4 w-4" />
                    <span class="text-sm text-gray-300 font-semibold">Enable Reports</span>
                </label>
                <label class="flex items-center gap-3 p-4 rounded-xl bg-white/[0.02] border border-white/[0.05]">
                    <input asp-for="EnableCosting" type="checkbox" class="h-4 w-4" />
                    <span class="text-sm text-gray-300 font-semibold">Enable Costing</span>
                </label>
                <label class="flex items-center gap-3 p-4 rounded-xl bg-white/[0.02] border border-white/[0.05]">
                    <input asp-for="EnableAuditLogs" type="checkbox" class="h-4 w-4" />
                    <span class="text-sm text-gray-300 font-semibold">Enable Audit Logs</span>
                </label>
            </div>

            <div class="flex items-center gap-3">
                <button type="submit" class="px-6 py-2.5 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all">Save</button>
                <a href="/superadmin/plans" class="px-6 py-2.5 bg-white/[0.03] hover:bg-white/[0.08] text-gray-300 text-sm font-bold rounded-xl border border-white/[0.05] transition-all">Cancel</a>
            </div>
        </form>
    </div>
</div>
