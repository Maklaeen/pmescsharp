@model List<PmesCSharp.Models.Material>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Materials Management";
    int page = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
}

@if (TempData["Success"] is string success)
{
    <div class="mb-6 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm px-4 py-3 rounded-xl">
        @success
    </div>
}

@if (TempData["Error"] is string error)
{
    <div class="mb-6 bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-4 py-3 rounded-xl">
        @error
    </div>
}

<div class="bg-[#111114] border border-white/[0.05] rounded-[24px] p-8">
    <div class="flex items-center justify-between mb-10">
        <div>
            <h2 class="text-2xl font-bold text-white tracking-tight">Materials</h2>
            <p class="text-sm text-gray-500 mt-1">Maintain raw materials, unit costs, and on-hand stock.</p>
        </div>
        <a href="/admin/materials/create" class="px-6 py-3 bg-orange-600 hover:bg-orange-700 text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-orange-900/20">
            Add Material
        </a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-separate border-spacing-y-3">
            <thead>
                <tr class="text-[11px] font-bold text-gray-600 uppercase tracking-widest">
                    <th class="px-6 py-4">Material</th>
                    <th class="px-6 py-4">Unit</th>
                    <th class="px-6 py-4">Unit Cost</th>
                    <th class="px-6 py-4">On Hand</th>
                    <th class="px-6 py-4">Reorder</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="px-6 py-16 text-center text-gray-500 text-sm">No materials found. Add your first material.</td>
                    </tr>
                }
                @foreach (var m in Model)
                {
                    var statusClass = m.Status == "active"
                        ? "text-emerald-300 bg-emerald-500/10 border-emerald-500/20"
                        : "text-gray-300 bg-white/5 border-white/10";
                    <tr class="bg-white/[0.02] hover:bg-white/[0.05] transition-colors group">
                        <td class="px-6 py-5 rounded-l-2xl border-y border-l border-white/[0.05]">
                            <div class="text-sm font-bold text-white">@m.MaterialName</div>
                            <div class="text-xs text-gray-500">@m.MaterialCode</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-xs text-gray-300 font-semibold">@m.Unit</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-xs text-gray-300 font-semibold">@m.UnitCost.ToString("N2")</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-xs text-gray-300 font-semibold">@m.StockQuantity.ToString("G")</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <div class="text-xs text-gray-400">@m.ReorderLevel.ToString("G")</div>
                        </td>
                        <td class="px-6 py-5 border-y border-white/[0.05]">
                            <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-lg border @statusClass">
                                @m.Status
                            </span>
                        </td>
                        <td class="px-6 py-5 rounded-r-2xl border-y border-r border-white/[0.05] text-right">
                            <div class="inline-flex items-center gap-2">
                                <a href="/admin/materials/@m.Id/edit" class="px-4 py-2 text-xs font-bold rounded-xl bg-white/[0.03] hover:bg-white/[0.08] border border-white/[0.05] text-white transition-all">Edit</a>
                                <form method="post" action="/admin/materials/@m.Id/delete" onsubmit="return confirm('Delete this material?');" class="inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="px-4 py-2 text-xs font-bold rounded-xl bg-red-600/20 hover:bg-red-600/30 border border-red-500/30 text-red-300 transition-all">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="mt-6 flex items-center gap-2">
            @for (int i = 1; i <= totalPages; i++)
            {
                <a href="/admin/materials?page=@i" class="px-4 py-2 text-xs font-bold rounded-xl @(i == page ? "bg-orange-600 text-white" : "bg-white/[0.03] text-gray-400 hover:bg-white/[0.08]") border border-white/[0.05] transition-all">@i</a>
            }
        </div>
    }
</div>
